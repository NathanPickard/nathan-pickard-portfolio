---
import { Icon } from 'astro-icon/components';
import DarkLayout from '../layouts/DarkLayout.astro';
import DarkNav from '../components/DarkNav.astro';
import Footer from '../components/Footer.astro';
import resumeData from '../data/resume.json';
const activities = resumeData.activities;

const work = [
  {
    co: 'Harbor ATS',
    client: 'HR / AI startup',
    role: 'Founding Senior Full-Stack Engineer',
    period: 'Mar 2026 – present',
    blurb:
      'Architecting an AI-powered applicant tracking system from the ground up — human-in-the-loop matching, automated candidate re-engagement, and a real-time analytics engine for hiring funnel health.',
    stack: [],
    wins: [],
  },
  {
    co: 'Kellton',
    client: 'Best Egg (fintech)',
    role: 'Senior Software Engineer',
    period: '2020 – 2025',
    blurb:
      'Owned offer and refinancing flows across Angular, React, and Vue for a 2M+ user consumer lending platform. The UI work contributed to J.D. Power #1 rankings in 2024 and 2025.',
    stack: [
      'Angular',
      'React',
      'Vue',
      'TypeScript',
      'Node.js',
      'Python',
      'NgRx',
      'Redux',
      'Django',
      'MongoDB',
      'Tailwind',
      'Angular Material',
      'Ansible',
      'Karma',
      'Jasmine',
      'Jest',
    ],
    wins: ['+23% conversion', '$200M originations', 'J.D. Power #1'],
  },
  {
    co: 'Lazarus Naturals',
    client: 'Wellness DTC',
    role: 'Frontend Developer',
    period: '2020',
    blurb:
      "Shipped the company's first native app, launched three new product categories, and modernized the e-commerce storefront during a period of fast expansion.",
    stack: ['React', 'Node.js', 'Wordpress'],
    wins: ['+24% native-app sales', '+32% month-over-month traffic'],
  },
  {
    co: 'Mental Health Match',
    client: 'Healthtech',
    role: 'Angular Developer',
    period: '2019',
    blurb:
      'Worked with the CTO and CEO to rebuild therapist-matching onboarding. Reduced load time 28%, grew therapist signups 31% in three months.',
    stack: ['Angular', 'AWS', 'Firebase'],
    wins: ['+35% conversion', '+31% therapist onboarding', '−28% load time'],
  },
  {
    co: 'Freelance',
    client: '',
    role: 'Web Developer',
    period: '2017 – 2019',
    blurb:
      'Early-stage product work, small-business sites, and internal tools across the JS/TS stack.',
    stack: ['JavaScript', 'Angular', 'Node.js', 'AWS'],
    wins: [],
  },
];

// Keywords to skip entirely in the icon grid (no tile rendered)
const skipTiles = new Set(['Less', 'Wordpress']);

// Display label overrides for the icon grid
const labelOverrides: Record<string, string> = {
  'AWS (Lambda, S3, API Gateway)': 'Amazon Web Services',
  AWS: 'AWS',
};

// DevOps keywords used to split Tools/Infrastructure into Backend vs DevOps & Infra panels
const devopsKeywords = new Set([
  'AWS (Lambda, S3, API Gateway)',
  'Docker',
  'Ansible',
  'Datadog',
  'FullStory',
  'Nginx',
  'GitHub Actions CI/CD',
]);

// Keywords from Languages/Frameworks that belong in the Backend panel instead
const movedToBackend = new Set(['Node.js', 'Django', 'Python']);

// Helper to find keywords by category name from resumeData.skills
const getKeywords = (name: string): string[] =>
  resumeData.skills.find((s) => s.name === name)?.keywords ?? [];

const toolsKeywords = getKeywords('Tools/Infrastructure');
const backendKeywords = [
  // Node.js and Django pulled from Languages/Frameworks
  ...getKeywords('Languages/Frameworks').filter((kw) => movedToBackend.has(kw)),
  // Tools/Infrastructure minus devops keywords
  ...toolsKeywords.filter((kw) => !devopsKeywords.has(kw) && !skipTiles.has(kw)),
];
const devopsFilteredKeywords = toolsKeywords.filter(
  (kw) => devopsKeywords.has(kw) && !skipTiles.has(kw),
);

// Panel configuration for the bento grid
const panelConfig = [
  {
    id: 'frontend',
    label: 'FRONTEND',
    accent: '#d4af37',
    type: 'icon',
    keywords: getKeywords('Languages/Frameworks').filter(
      (kw) => !skipTiles.has(kw) && !movedToBackend.has(kw),
    ),
  },
  {
    id: 'backend',
    label: 'BACKEND',
    accent: '#d4af37',
    type: 'icon',
    keywords: backendKeywords,
  },
  {
    id: 'devops',
    label: 'DEVOPS & INFRASTRUCTURE',
    accent: '#b07fd4',
    type: 'icon',
    keywords: devopsFilteredKeywords,
  },
  {
    id: 'testing',
    label: 'TESTING',
    accent: '#f06292',
    type: 'icon',
    keywords: getKeywords('Testing & Quality').filter(
      (kw) => !skipTiles.has(kw),
    ),
  },
  {
    id: 'specializations',
    label: 'SPECIALIZATIONS',
    accent: '#d4af37',
    type: 'tag',
    keywords: getKeywords('Specializations'),
  },
  {
    id: 'ai-tools',
    label: 'AI & TOOLS',
    accent: '#b07fd4',
    type: 'tag',
    keywords: getKeywords('AI Models & Tools'),
  },
];

// Map skill keywords to devicon names
const iconMap: Record<string, string | null> = {
  JavaScript: 'devicon:javascript',
  TypeScript: 'devicon:typescript',
  Angular: 'devicon:angular',
  React: 'devicon:react',
  Vue: 'devicon:vuejs',
  'Node.js': 'devicon:nodejs',
  Python: 'devicon:python',
  Django: 'devicon:python',
  NgRx: 'devicon:redux',
  Redux: 'devicon:redux',
  Tailwind: 'devicon:tailwindcss',
  'Angular Material': 'devicon:angularmaterial',
  HTML5: 'devicon:html5',
  CSS: 'devicon:css3',
  SCSS: 'devicon:sass',
  Less: null,
  Bootstrap: 'devicon:bootstrap',
  'AWS (Lambda, S3, API Gateway)': 'devicon:amazonwebservices',
  AWS: 'devicon:amazonwebservices',
  Docker: 'devicon:docker',
  MongoDB: 'devicon:mongodb',
  MySQL: 'devicon:mysql',
  Datadog: 'devicon:datadog',
  FullStory: null,
  Nginx: 'devicon:nginx',
  'GitHub Actions CI/CD': 'devicon:github',
  Ansible: 'devicon:ansible',
  Karma: 'devicon:karma',
  Jasmine: 'devicon:jasmine',
  Jest: null,
  Vitest: 'devicon:vitest',
  pytest: 'devicon:pytest',
  Mocha: 'devicon:mocha',
  Chai: null,
  Firebase: 'devicon:firebase',
  'GitHub Copilot': 'devicon:github',
  'Claude Code': null,
  Gemini: null,
  'OpenAI API': null,
  Cursor: null,
  Kiro: null,
  'Software architecture': null,
  Fintech: null,
  'Accessibility/WCAG': null,
  'AI implementation': null,
  'UI/UX optimization': null,
  'A/B tests': null,
};
---

<DarkLayout
  title="Work — Nathan Pickard"
  description="Six years shipping consumer-facing software in fintech, wellness, and healthtech."
>
  <DarkNav />

  <main class="work-main">
    <div class="work-inner">
      <div class="work-header">
        <span class="section-label">Work History</span>
        <h1 class="work-h1">From idea to impact</h1>
        <p class="work-sub">Work that ships and results that stick</p>
      </div>

      {/* Icon sprite preloader — keeps astro-icon SVG symbols in the always-visible DOM
          so icons in hidden .work-panel tabs don't break the bento grid */}
      <div aria-hidden="true" style="position:absolute;width:0;height:0;overflow:hidden;">
        {Object.values(iconMap).filter((v): v is string => v !== null).filter((v, i, a) => a.indexOf(v) === i).map((name) => (
          <Icon name={name} size={1} />
        ))}
      </div>

      <div class="work-grid" id="work-grid">
        <!-- Desktop tabs sidebar -->
        <div class="work-tabs" role="tablist" aria-label="Work history">
          {
            work.map((w, i) => (
              <button
                class={`work-tab${i === 0 ? ' active' : ''}`}
                role="tab"
                aria-selected={i === 0 ? 'true' : 'false'}
                aria-controls={`panel-${i}`}
                id={`tab-${i}`}
                data-index={i}
                data-mobile-open={i === 0 ? 'true' : 'false'}
              >
                <div class="tab-co">{w.co}</div>
                <div class="tab-period">{w.period}</div>
                <div class="tab-role">{w.role}</div>
              </button>
            ))
          }
        </div>

        <!-- Desktop panels -->
        <div class="work-panels">
          {
            work.map((w, i) => (
              <div
                class={`work-panel${i === 0 ? ' active' : ''}`}
                role="tabpanel"
                id={`panel-${i}`}
                aria-labelledby={`tab-${i}`}
              >
                <div class="detail-role">{w.role}</div>
                {w.client && <div class="detail-client">{w.client}</div>}
                <p class="detail-blurb">{w.blurb}</p>
                {w.wins.length > 0 && (
                  <div class="detail-wins">
                    {w.wins.map((win) => (
                      <span class="win">{win}</span>
                    ))}
                  </div>
                )}
                <div class="detail-stack">
                  {w.stack
                    .filter((s) => !skipTiles.has(s))
                    .map((s) => {
                      const icon = iconMap[s];
                      return (
                        <div class="skill-icon-tile">
                          {icon ? (
                            <Icon
                              name={icon}
                              size={28}
                              aria-hidden="true"
                              class="skill-icon"
                            />
                          ) : (
                            <span
                              class="skill-icon-fallback"
                              aria-hidden="true"
                            >
                              ✦
                            </span>
                          )}
                          <span class="skill-icon-label">
                            {labelOverrides[s] ?? s}
                          </span>
                        </div>
                      );
                    })}
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Mobile accordion (hidden on desktop) -->
      <div class="work-accordion" aria-label="Work history">
        {
          work.map((w, i) => (
            <div class="accordion-item">
              <button
                class={`accordion-trigger${i === 0 ? ' active' : ''}`}
                data-accordion-index={i}
                aria-expanded={i === 0 ? 'true' : 'false'}
                aria-controls={`accordion-panel-${i}`}
                id={`accordion-tab-${i}`}
              >
                <div class="accordion-header">
                  <div class="accordion-co">{w.co}</div>
                  <div class="accordion-meta">
                    <span class="accordion-period">{w.period}</span>
                    {w.client && <span class="accordion-client">{w.client}</span>}
                  </div>
                </div>
                <span class="accordion-chevron" aria-hidden="true">›</span>
              </button>
              <div
                class={`accordion-panel${i === 0 ? ' open' : ''}`}
                id={`accordion-panel-${i}`}
                role="region"
                aria-labelledby={`accordion-tab-${i}`}
              >
                <div class="accordion-content">
                  <div class="detail-role">{w.role}</div>
                  <p class="detail-blurb">{w.blurb}</p>
                  {w.wins.length > 0 && (
                    <div class="detail-wins">
                      {w.wins.map((win) => (
                        <span class="win">{win}</span>
                      ))}
                    </div>
                  )}
                  <div class="detail-stack">
                    {w.stack
                      .filter((s) => !skipTiles.has(s))
                      .map((s) => {
                        const icon = iconMap[s];
                        return (
                          <div class="skill-icon-tile">
                            {icon ? (
                              <Icon
                                name={icon}
                                size={28}
                                aria-hidden="true"
                                class="skill-icon"
                              />
                            ) : (
                              <span
                                class="skill-icon-fallback"
                                aria-hidden="true"
                              >
                                ✦
                              </span>
                            )}
                            <span class="skill-icon-label">
                              {labelOverrides[s] ?? s}
                            </span>
                          </div>
                        );
                      })}
                  </div>
                </div>
              </div>
            </div>
          ))
        }
      </div>

      <section class="skills-section" aria-labelledby="skills-heading">
        <span class="section-label">Technical Skills</span>
        <h2 class="skills-h2" id="skills-heading">The tools I reach for</h2>
        <div class="bento-grid">
          {
            panelConfig.map((panel) => (
              <div
                class="bento-panel"
                data-panel-id={panel.id}
                style={`--accent: ${panel.accent}`}
              >
                <h3 class="bento-panel-heading">{panel.label}</h3>
                {panel.type === 'icon' ? (
                  <div class="skill-icons">
                    {panel.keywords.map((kw) => {
                      const icon = iconMap[kw];
                      return (
                        <div class="skill-icon-tile">
                          {icon ? (
                            <Icon
                              name={icon}
                              size={28}
                              aria-hidden="true"
                              class="skill-icon"
                            />
                          ) : (
                            <span
                              class="skill-icon-fallback"
                              aria-hidden="true"
                            >
                              ✦
                            </span>
                          )}
                          <span class="skill-icon-label">
                            {labelOverrides[kw] ?? kw}
                          </span>
                        </div>
                      );
                    })}
                  </div>
                ) : (
                  <div class="spec-pills">
                    {panel.keywords.map((kw) => (
                      <span class="spec-pill">{kw}</span>
                    ))}
                  </div>
                )}
              </div>
            ))
          }
        </div>
      </section>

      <section class="community-section" aria-labelledby="community-heading">
        <span class="section-label">Community</span>
        <h2 class="community-h2" id="community-heading">In the community</h2>
        <div class="community-body">
          {
            activities.map((activity) => (
              <p class="community-text">{activity}</p>
            ))
          }
        </div>
      </section>

      <div class="work-cta-row">
        <a href="/resume" class="btn-primary">View full resume →</a>
      </div>
    </div>
  </main>

  <Footer />
</DarkLayout>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.work-tab');
  const panels = document.querySelectorAll<HTMLDivElement>('.work-panel');

  // Desktop tab behavior
  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const idx = Number(tab.dataset.index);
      tabs.forEach((t, i) => {
        t.classList.toggle('active', i === idx);
        t.setAttribute('aria-selected', String(i === idx));
      });
      panels.forEach((p, i) => p.classList.toggle('active', i === idx));
    });
  });

  // Mobile accordion behavior
  const accordionTriggers = document.querySelectorAll<HTMLButtonElement>('.accordion-trigger');
  const accordionPanels = document.querySelectorAll<HTMLDivElement>('.accordion-panel');

  accordionTriggers.forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const idx = Number(trigger.dataset.accordionIndex);
      const isOpen = trigger.getAttribute('aria-expanded') === 'true';

      // Close all
      accordionTriggers.forEach((t) => {
        t.classList.remove('active');
        t.setAttribute('aria-expanded', 'false');
      });
      accordionPanels.forEach((p) => p.classList.remove('open'));

      // Open clicked (toggle — if it was open, leave closed)
      if (!isOpen) {
        trigger.classList.add('active');
        trigger.setAttribute('aria-expanded', 'true');
        accordionPanels[idx].classList.add('open');
      }
    });
  });
</script>

<style>
  .work-main {
    padding: 80px 60px;
  }
  .work-inner {
    max-width: 1240px;
    margin: 0 auto;
  }
  .work-header {
    margin-bottom: 48px;
  }
  .section-label {
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #e2ede6;
    display: block;
    margin-bottom: 16px;
  }
  .work-h1 {
    font-family: 'Fraunces', serif;
    font-weight: 400;
    font-variation-settings: 'opsz' 72;
    font-size: clamp(32px, 4vw, 52px);
    line-height: 1;
    letter-spacing: -0.03em;
    margin: 0 0 12px;
    color: #e2ede6;
  }
  .work-sub {
    font-size: 16px;
    color: #e2ede6;
    margin: 0;
  }

  .work-grid {
    display: none;
    grid-template-columns: 240px 1fr;
    border: 1px solid rgba(137, 174, 151, 0.2);
    border-radius: 10px;
    overflow: hidden;
    max-width: fit-content;
  }
  @media (min-width: 700px) {
    .work-grid {
      display: grid;
    }
    .work-accordion {
      display: none;
    }
  }
  .work-tabs {
    border-right: 1px solid rgba(137, 174, 151, 0.2);
  }
  .work-tab {
    width: 100%;
    background: transparent;
    border: 0;
    border-bottom: 1px solid rgba(137, 174, 151, 0.2);
    padding: 20px 24px;
    text-align: left;
    cursor: pointer;
    transition: background 0.15s;
    color: #ede8d8;
  }
  .work-tab:last-child {
    border-bottom: 0;
  }
  .work-tab:hover {
    background: rgba(255, 255, 255, 0.04);
  }
  .work-tab.active {
    background: #162b1b;
    border-left: 3px solid #d4af37;
  }
  .tab-co {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-variation-settings: 'opsz' 72;
    font-size: 18px;
    letter-spacing: -0.01em;
    color: #ede8d8;
  }
  .tab-period {
    font-size: 11px;
    font-family: 'Geist Mono', monospace;
    color: #a8c8b4;
    margin-top: 4px;
  }
  .tab-role {
    display: none;
  }

  .work-panels {
    background: #162b1b;
  }
  .work-panel {
    display: none;
    padding: 36px;
  }
  .work-panel.active {
    display: block;
  }

  .detail-role {
    font-weight: 600;
    font-size: 16px;
    margin-bottom: 4px;
    color: #ede8d8;
  }
  .detail-client {
    font-size: 12px;
    font-family: 'Geist Mono', monospace;
    color: #a8c8b4;
    margin-bottom: 20px;
  }
  .detail-blurb {
    font-size: 15px;
    line-height: 1.7;
    color: #e2ede6;
    margin: 0 0 24px;
    max-width: 560px;
  }
  .detail-wins {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 24px;
  }
  .win {
    background: rgba(212, 175, 55, 0.15);
    color: #d4af37;
    padding: 5px 14px;
    border-radius: 999px;
    font:
      500 12px 'Geist Mono',
      monospace;
  }
  .detail-stack {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .pill {
    display: inline-block;
    padding: 4px 12px;
    border: 1px solid rgba(137, 174, 151, 0.2);
    border-radius: 999px;
    font:
      500 12px 'Geist Mono',
      monospace;
    color: #d9d0bc;
  }

  @media (max-width: 900px) {
    .work-main {
      padding: 60px 24px;
    }
    .bento-panel {
      padding: 16px;
    }
    .skill-icons {
      gap: 8px;
    }
    .skill-icon-tile {
      min-width: 60px;
      padding: 10px 8px;
    }
    .skill-icon-label {
      font-size: 11px;
    }
    .spec-pills {
      gap: 8px;
    }
    .spec-pill {
      font-size: 12px;
      padding: 6px 12px;
    }
  }

  @media (max-width: 768px) {
    .bento-panel {
      padding: 16px;
    }
    .skill-icons {
      gap: 8px;
    }
    .skill-icon-tile {
      min-width: 60px;
      padding: 10px 8px;
    }
    .skill-icon-label {
      font-size: 11px;
    }
    .spec-pills {
      gap: 8px;
    }
    .spec-pill {
      font-size: 12px;
      padding: 6px 12px;
    }
  }

  /* Mobile accordion — hidden on desktop */
  .work-accordion {
    display: block;
    border: 1px solid rgba(137, 174, 151, 0.2);
    border-radius: 10px;
    overflow: hidden;
  }
  .accordion-item {
    border-bottom: 1px solid rgba(137, 174, 151, 0.2);
  }
  .accordion-item:last-child {
    border-bottom: 0;
  }
  .accordion-trigger {
    width: 100%;
    background: transparent;
    border: 0;
    padding: 20px 24px;
    text-align: left;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    color: #ede8d8;
    transition: background 0.15s;
  }
  .accordion-trigger:hover {
    background: rgba(255, 255, 255, 0.04);
  }
  .accordion-trigger.active {
    background: #162b1b;
    border-left: 3px solid #d4af37;
  }
  .accordion-header {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }
  .accordion-co {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-variation-settings: 'opsz' 72;
    font-size: 20px;
    letter-spacing: -0.01em;
    color: #ede8d8;
  }
  .accordion-meta {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    align-items: center;
  }
  .accordion-period {
    font-size: 11px;
    font-family: 'Geist Mono', monospace;
    color: #a8c8b4;
  }
  .accordion-client {
    font-size: 11px;
    font-family: 'Geist Mono', monospace;
    color: #a8c8b4;
  }
  .accordion-client::before {
    content: '·';
    margin-right: 10px;
  }
  .accordion-chevron {
    font-size: 22px;
    color: #a8c8b4;
    flex-shrink: 0;
    transition: transform 0.2s;
    line-height: 1;
  }
  .accordion-trigger.active .accordion-chevron {
    transform: rotate(90deg);
  }
  .accordion-panel {
    display: none;
    background: #162b1b;
  }
  .accordion-panel.open {
    display: block;
  }
  .accordion-content {
    padding: 20px 24px 28px;
  }
  .accordion-content .detail-role {
    margin-bottom: 12px;
  }

  /* Skills section */
  .skills-section {
    margin-top: 64px;
    padding-top: 64px;
    border-top: 1px solid rgba(137, 174, 151, 0.2);
  }
  .skills-h2 {
    font-family: 'Fraunces', serif;
    font-weight: 400;
    font-variation-settings: 'opsz' 72;
    font-size: clamp(28px, 3.5vw, 44px);
    line-height: 1.05;
    letter-spacing: -0.025em;
    margin: 0 0 40px;
    color: #e2ede6;
  }
  .bento-grid {
    display: grid;
    grid-template-columns: 1fr;
    border: 1px solid rgba(137, 174, 151, 0.2);
    border-radius: 10px;
    overflow: hidden;
    background: #162b1b;
    margin-top: 32px;
