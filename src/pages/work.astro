---
import { Icon } from 'astro-icon/components';
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import WorkCardContent from '../components/WorkCardContent.astro';
import resumeData from '../data/resume.json';
import {
  iconMap,
  labelOverrides,
  skipTiles,
  devopsKeywords,
  movedToBackend,
} from '../data/workIconMap';
const activities = resumeData.activities;

const work = [
  {
    co: 'Harbor ATS',
    client: 'HR / AI startup',
    role: 'Founding Senior Full-Stack Engineer',
    period: 'Mar 2026 – present',
    blurb:
      'Architecting an AI-powered applicant tracking system from the ground up — human-in-the-loop matching, automated candidate re-engagement, and a real-time analytics engine for hiring funnel health.',
    stack: [],
    wins: [],
  },
  {
    co: 'Kellton',
    client: 'Best Egg (Fintech)',
    role: 'Senior Software Engineer',
    period: '2020 – 2025',
    blurb:
      'Owned offer and refinancing flows across Angular, React, and Vue for a 2M+ user consumer lending platform. The UI work contributed to J.D. Power #1 rankings in 2024 and 2025.',
    stack: [
      'Angular',
      'React',
      'Vue',
      'TypeScript',
      'Node.js',
      'Python',
      'NgRx',
      'Redux',
      'Django',
      'MongoDB',
      'Tailwind',
      'Angular Material',
      'Ansible',
      'Karma',
      'Jasmine',
      'Jest',
    ],
    wins: ['+23% conversion', '$200M originations', 'J.D. Power #1'],
  },
  {
    co: 'Lazarus Naturals',
    client: 'Wellness DTC',
    role: 'Frontend Developer',
    period: '2020',
    blurb:
      "Shipped the company's first native app, launched three new product categories, and modernized the e-commerce storefront during a period of fast expansion.",
    stack: ['React', 'Node.js', 'Wordpress'],
    wins: ['+24% native-app sales', '+32% month-over-month traffic'],
  },
  {
    co: 'Mental Health Match',
    client: 'Healthtech',
    role: 'Angular Developer',
    period: '2019',
    blurb:
      'Worked with the CTO and CEO to rebuild therapist-matching onboarding. Reduced load time 28%, grew therapist signups 31% in three months.',
    stack: ['Angular', 'AWS', 'Firebase'],
    wins: ['+35% conversion', '+31% therapist onboarding', '−28% load time'],
  },
  {
    co: 'Freelance',
    client: '',
    role: 'Web Developer',
    period: '2017 – 2019',
    blurb:
      'Early-stage product work, small-business sites, and internal tools across the JS/TS stack.',
    stack: ['JavaScript', 'Angular', 'Node.js', 'AWS'],
    wins: [],
  },
];

// Helper to find keywords by category name from resumeData.skills
const getKeywords = (name: string): string[] =>
  resumeData.skills.find((s) => s.name === name)?.keywords ?? [];

const toolsKeywords = getKeywords('Tools/Infrastructure');
const backendKeywords = [
  // Node.js and Django pulled from Languages/Frameworks
  ...getKeywords('Languages/Frameworks').filter((kw) => movedToBackend.has(kw)),
  // Tools/Infrastructure minus devops keywords
  ...toolsKeywords.filter(
    (kw) => !devopsKeywords.has(kw) && !skipTiles.has(kw),
  ),
];
const devopsFilteredKeywords = toolsKeywords.filter(
  (kw) => devopsKeywords.has(kw) && !skipTiles.has(kw),
);

// Panel configuration for the bento grid
const panelConfig = [
  {
    id: 'frontend',
    label: 'FRONTEND',
    accent: '#d4af37',
    type: 'icon',
    keywords: getKeywords('Languages/Frameworks').filter(
      (kw) => !skipTiles.has(kw) && !movedToBackend.has(kw),
    ),
  },
  {
    id: 'backend',
    label: 'BACKEND',
    accent: '#d4af37',
    type: 'icon',
    keywords: backendKeywords,
  },
  {
    id: 'devops',
    label: 'DEVOPS & INFRASTRUCTURE',
    accent: '#b07fd4',
    type: 'icon',
    keywords: devopsFilteredKeywords,
  },
  {
    id: 'testing',
    label: 'TESTING',
    accent: '#f06292',
    type: 'icon',
    keywords: getKeywords('Testing & Quality').filter(
      (kw) => !skipTiles.has(kw),
    ),
  },
  {
    id: 'specializations',
    label: 'SPECIALIZATIONS',
    accent: '#d4af37',
    type: 'tag',
    keywords: getKeywords('Specializations'),
  },
  {
    id: 'ai-tools',
    label: 'AI & TOOLS',
    accent: '#b07fd4',
    type: 'tag',
    keywords: getKeywords('AI Models & Tools'),
  },
];
---

<BaseLayout
  title="Work — Nathan Pickard"
  description="Six years shipping consumer-facing software in fintech, wellness, and healthtech."
>
  <Nav />

  <main class="work-main">
    <div class="work-inner">
      <div class="work-header" data-reveal>
        <h1 class="work-h1">From idea to impact</h1>
        <p class="work-sub">Work that ships and results that stick</p>
      </div>

      {
        /* Icon sprite preloader — keeps astro-icon SVG symbols in the always-visible DOM
          so icons in hidden .work-panel tabs don't break the bento grid */
      }
      <div
        aria-hidden="true"
        style="position:absolute;width:0;height:0;overflow:hidden;"
      >
        {
          Object.values(iconMap)
            .filter((v): v is string => v !== null)
            .filter((v, i, a) => a.indexOf(v) === i)
            .map((name) => <Icon name={name} size={1} />)
        }
      </div>

      <div class="work-grid" id="work-grid" data-reveal>
        <!-- Desktop tabs sidebar -->
        <div class="work-tabs" role="tablist" aria-label="Work history">
          {
            work.map((w, i) => (
              <button
                class={`work-tab${i === 0 ? ' active' : ''}`}
                role="tab"
                aria-selected={i === 0 ? 'true' : 'false'}
                aria-controls={`panel-${i}`}
                id={`tab-${i}`}
                data-index={i}
                data-mobile-open={i === 0 ? 'true' : 'false'}
              >
                <div class="tab-co">{w.co}</div>
                <div class="tab-period">{w.period}</div>
                <div class="tab-role">{w.role}</div>
              </button>
            ))
          }
        </div>  

        <!-- Desktop panels -->
        <div class="work-panels">
          {
            work.map((w, i) => (
              <div
                class={`work-panel${i === 0 ? ' active' : ''}`}
                role="tabpanel"
                id={`panel-${i}`}
                aria-labelledby={`tab-${i}`}
              >
                <WorkCardContent
                  role={w.role}
                  client={w.client || undefined}
                  blurb={w.blurb}
                  wins={w.wins}
                  stack={w.stack}
                />
              </div>
            ))
          }
        </div>
      </div>

      <!-- Mobile accordion (hidden on desktop) -->
      <div class="work-accordion" aria-label="Work history" data-reveal>
        {
          work.map((w, i) => (
            <div class="accordion-item">
              <button
                class={`accordion-trigger${i === 0 ? ' active' : ''}`}
                data-accordion-index={i}
                aria-expanded={i === 0 ? 'true' : 'false'}
                aria-controls={`accordion-panel-${i}`}
                id={`accordion-tab-${i}`}
              >
                <div class="accordion-header">
                  <div class="accordion-co">{w.co}</div>
                  <div class="accordion-meta">
                    <span class="accordion-period">{w.period}</span>
                    {w.client && (
                      <span class="accordion-client">{w.client}</span>
                    )}
                  </div>
                </div>
                <span class="accordion-chevron" aria-hidden="true">
                  ›
                </span>
              </button>
              <div
                class={`accordion-panel${i === 0 ? ' open' : ''}`}
                id={`accordion-panel-${i}`}
                role="region"
                aria-labelledby={`accordion-tab-${i}`}
              >
                <div class="accordion-content">
                  <WorkCardContent
                    role={w.role}
                    blurb={w.blurb}
                    wins={w.wins}
                    stack={w.stack}
                  />
                </div>
              </div>
            </div>
          ))
        }
      </div>

      <section class="skills-section" aria-labelledby="skills-heading">
        <h2 class="skills-h2" id="skills-heading" data-reveal>The tools I reach for</h2>
        <div class="bento-grid" data-reveal-stagger>
          {
            panelConfig.map((panel) => (
              <div
                class="bento-panel"
                data-panel-id={panel.id}
                style={`--accent: ${panel.accent}`}
                data-reveal
              >
                <h3 class="bento-panel-heading">{panel.label}</h3>
                {panel.type === 'icon' ? (
                  <div class="skill-icons">
                    {panel.keywords.map((kw) => {
                      const icon = iconMap[kw];
                      return (
                        <div class="skill-icon-tile">
                          {icon ? (
                            <Icon
                              name={icon}
                              size={28}
                              aria-hidden="true"
                              class="skill-icon"
                            />
                          ) : (
                            <span
                              class="skill-icon-fallback"
                              aria-hidden="true"
                            >
                              ✦
                            </span>
                          )}
                          <span class="skill-icon-label">
                            {labelOverrides[kw] ?? kw}
                          </span>
                        </div>
                      );
                    })}
                  </div>
                ) : (
                  <div class="spec-pills">
                    {panel.keywords.map((kw) => (
                      <span class="spec-pill">{kw}</span>
                    ))}
                  </div>
                )}
              </div>
            ))
          }
        </div>
      </section>

      <section class="community-section" aria-labelledby="community-heading" data-reveal>
        <h2 class="community-h2" id="community-heading">In the community</h2>
        <div class="community-body">
          {
            activities.map((activity) => (
              <p class="community-text">{activity}</p>
            ))
          }
        </div>
      </section>

      <div class="work-cta-row" data-reveal>
        <a href="/resume" class="btn-primary">View full resume →</a>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.work-tab');
  const panels = document.querySelectorAll<HTMLDivElement>('.work-panel');

  // Desktop tab behavior
  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const idx = Number(tab.dataset.index);
      tabs.forEach((t, i) => {
        t.classList.toggle('active', i === idx);
        t.setAttribute('aria-selected', String(i === idx));
      });
      panels.forEach((p, i) => p.classList.toggle('active', i === idx));
    });
  });

  // Mobile accordion behavior
  const accordionTriggers =
    document.querySelectorAll<HTMLButtonElement>('.accordion-trigger');
  const accordionPanels =
    document.querySelectorAll<HTMLDivElement>('.accordion-panel');

  accordionTriggers.forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const idx = Number(trigger.dataset.accordionIndex);
      const isOpen = trigger.getAttribute('aria-expanded') === 'true';

      // Close all
      accordionTriggers.forEach((t) => {
        t.classList.remove('active');
        t.setAttribute('aria-expanded', 'false');
      });
      accordionPanels.forEach((p) => p.classList.remove('open'));

      // Open clicked (toggle — if it was open, leave closed)
      if (!isOpen) {
        trigger.classList.add('active');
        trigger.setAttribute('aria-expanded', 'true');
        accordionPanels[idx].classList.add('open');
      }
    });
  });
</script>

<style>
  .work-main {
    padding: 80px 60px;
  }
  .work-inner {
    max-width: 1240px;
    margin: 0 auto;
  }
  .work-header {
    margin-bottom: 48px;
  }
  .work-h1 {
    font-family: var(--font-eb-garamond);
    font-weight: 400;
    font-variation-settings: 'opsz' 72;
    font-size: clamp(28px, 3.6vw, 44px);
    line-height: 1;
    letter-spacing: var(--tracking-heading);
    margin: 0 0 12px;
    color: #e2ede6;
  }
  .work-sub {
    font-size: 16px;
    color: #e2ede6;
    margin: 0;
  }

  .work-grid {
    display: none;
    grid-template-columns: 240px 1fr;
    border: 1px solid rgba(137, 174, 151, 0.2);
    border-radius: 10px;
    overflow: hidden;
    max-width: fit-content;
  }
  @media (min-width: 700px) {
    .work-grid {
      display: grid;
    }
    .work-accordion {
      display: none;
    }
  }
  .work-tabs {
    border-right: 1px solid rgba(137, 174, 151, 0.2);
  }
  .work-tab {
    width: 100%;
    background: transparent;
    border: 0;
    border-bottom: 1px solid rgba(137, 174, 151, 0.2);
    padding: 20px 24px;
    text-align: left;
    cursor: pointer;
    transition: background 0.15s;
    color: #ede8d8;
  }
  .work-tab:last-child {
    border-bottom: 0;
  }
  .work-tab:hover {
    background: rgba(255, 255, 255, 0.04);
  }
  .work-tab.active {
    background: #162b1b;
    border-left: 3px solid #d4af37;
  }
  .tab-co {
    font-family: var(--font-eb-garamond);
    font-weight: 500;
    font-variation-settings: 'opsz' 72;
    font-size: 18px;
    letter-spacing: -0.01em;
    color: #ede8d8;
  }
  .tab-period {
    font-size: 11px;
    font-family: var(--font-geist-mono);
    color: #a8c8b4;
    margin-top: 4px;
  }
  .tab-role {
    display: none;
  }

  .work-panels {
    background: #162b1b;
  }
  .work-panel {
    display: none;
    padding: 36px;
  }
  .work-panel.active {
    display: block;
  }

  @media (max-width: 900px) {
    .work-main {
      padding: 60px 24px;
    }
    .bento-panel {
      padding: 16px;
    }
    .skill-icons {
      gap: 8px;
    }
    .skill-icon-tile {
      min-width: 60px;
      padding: 10px 8px;
    }
    .skill-icon-label {
      font-size: 11px;
    }
    .spec-pills {
      gap: 8px;
    }
    .spec-pill {
      font-size: 12px;
      padding: 6px 12px;
    }
  }

  @media (max-width: 768px) {
    .bento-panel {
      padding: 16px;
    }
    .skill-icons {
      gap: 8px;
    }
    .skill-icon-tile {
      min-width: 60px;
      padding: 10px 8px;
    }
    .skill-icon-label {
      font-size: 11px;
    }
    .spec-pills {
      gap: 8px;
    }
    .spec-pill {
      font-size: 12px;
      padding: 6px 12px;
    }
  }

  /* Mobile accordion — hidden on desktop */
  .work-accordion {
    display: block;
    border: 1px solid rgba(137, 174, 151, 0.2);
    border-radius: 10px;
    overflow: hidden;
  }
  @media (min-width: 700px) {
    .work-accordion {
      display: none !important;
    }
  }
  .accordion-item {
    border-bottom: 1px solid rgba(137, 174, 151, 0.2);
  }
  .accordion-item:last-child {
    border-bottom: 0;
  }
  .accordion-trigger {
    width: 100%;
    background: transparent;
    border: 0;
    padding: 20px 24px;
    text-align: left;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    color: #ede8d8;
    transition: background 0.15s;
  }
  .accordion-trigger:hover {
    background: rgba(255, 255, 255, 0.04);
  }
  .accordion-trigger.active {
    background: #162b1b;
    border-left: 3px solid #d4af37;
  }
  .accordion-header {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }
  .accordion-co {
    font-family: var(--font-eb-garamond);
    font-weight: 500;
    font-variation-settings: 'opsz' 72;
    font-size: 20px;
    letter-spacing: -0.01em;
    color: #ede8d8;
  }
  .accordion-meta {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    align-items: center;
  }
  .accordion-period {
    font-size: 11px;
    font-family: var(--font-geist-mono);
    color: #a8c8b4;
  }
  .accordion-client {
    font-size: 11px;
    font-family: var(--font-geist-mono);
    color: #a8c8b4;
  }
  .accordion-client::before {
    content: '·';
    margin-right: 10px;
  }
  .accordion-chevron {
    font-size: 22px;
    color: #a8c8b4;
    flex-shrink: 0;
    transition: transform 0.2s;
    line-height: 1;
  }
  .accordion-trigger.active .accordion-chevron {
    transform: rotate(90deg);
  }
  .accordion-panel {
    display: none;
    background: #162b1b;
  }
  .accordion-panel.open {
    display: block;
  }
  .accordion-content {
    padding: 20px 24px 28px;
  }
  .accordion-content .detail-role {
    margin-bottom: 12px;
  }

  /* Skills section */
  .skills-section {
    margin-top: 64px;
    padding-top: 64px;
    border-top: 1px solid rgba(137, 174, 151, 0.2);
  }
  .skills-h2 {
    font-family: var(--font-eb-garamond);
    font-weight: 400;
    font-variation-settings: 'opsz' 72;
    font-size: clamp(24px, 3vw, 36px);
    line-height: 1.05;
    letter-spacing: var(--tracking-sub);
    margin: 0 0 40px;
    color: #e2ede6;
  }
  .bento-grid {
    display: grid;
    grid-template-columns: 1fr;
    border: 1px solid rgba(137, 174, 151, 0.2);
    border-radius: 10px;
    overflow: hidden;
    background: #162b1b;
    margin-top: 32px;
  }
  @media (min-width: 700px) {
    .bento-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  .bento-panel {
    padding: 24px;
    border-bottom: 1px solid rgba(137, 174, 151, 0.2);
    border-top: 3px solid var(--accent);
  }
  .bento-panel:last-child {
    border-bottom: 0;
  }
  @media (min-width: 700px) {
    .bento-panel {
      border-right: 1px solid rgba(137, 174, 151, 0.2);
    }
    .bento-panel:nth-child(2n) {
      border-right: 0;
    }
    .bento-panel:nth-last-child(-n + 2) {
      border-bottom: 0;
    }
    .bento-panel:last-child {
      border-bottom: 0;
    }
  }
  .bento-panel-heading {
    font-family: var(--font-geist-mono);
    font-size: 11px;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 16px;
    font-weight: 500;
  }
  .skill-icons {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .skill-icon-tile {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 12px 10px;
    background: #f0ede4;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 8px;
    min-width: 72px;
    width: max-content;
    transition:
      border-color 0.2s,
      background 0.2s;
    cursor: default;
  }
  .skill-icon-tile:hover {
    border-color: rgba(0, 0, 0, 0.2);
    background: #e8e4da;
  }
  .skill-icon {
    width: 28px;
    height: 28px;
    flex-shrink: 0;
  }
  .skill-icon-fallback {
    font-size: 18px;
    color: #2d5a3d;
    line-height: 28px;
    display: block;
    text-align: center;
    width: 28px;
    height: 28px;
  }
  .skill-icon-label {
    font-family: var(--font-geist-mono);
    font-size: 12px;
    color: #1a2e1e;
    text-align: center;
    line-height: 1.3;
    white-space: nowrap;
  }
  /* Specializations / AI tools pills */
  .spec-pills {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .spec-pill {
    padding: 7px 16px;
    border: 1px solid rgba(137, 174, 151, 0.3);
    border-radius: 999px;
    font: 500 13px var(--font-geist-mono);
    color: #f0ece0;
    transition: border-color 0.2s;
  }
  .spec-pill:hover {
    border-color: rgba(137, 174, 151, 0.6);
  }

  /* Community section */
  .community-section {
    margin-top: 64px;
    padding-top: 64px;
    border-top: 1px solid rgba(137, 174, 151, 0.2);
  }
  .community-h2 {
    font-family: var(--font-eb-garamond);
    font-weight: 400;
    font-variation-settings: 'opsz' 72;
    font-size: clamp(28px, 3.5vw, 44px);
    line-height: 1.05;
    letter-spacing: -0.025em;
    margin: 0 0 24px;
    color: #e2ede6;
  }
  .community-text {
    font-size: 16px;
    line-height: 1.75;
    color: #e2ede6;
    max-width: 750px;
    margin: 0 0 16px;
  }
  .community-text:last-child {
    margin-bottom: 0;
  }

  /* Resume CTA */
  .work-cta-row {
    margin-top: 64px;
    padding-top: 64px;
    border-top: 1px solid rgba(137, 174, 151, 0.2);
    display: flex;
    gap: 14px;
  }
  .btn-primary {
    display: inline-block;
    padding: 13px 26px;
    background: #d4af37;
    color: #0d1c10;
    border-radius: 4px;
    font-weight: 600;
    font-size: 14px;
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: opacity 0.2s;
  }
  .btn-primary:hover {
    opacity: 0.85;
  }
</style>
