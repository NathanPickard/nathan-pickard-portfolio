---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import BlueskyFeed from '../components/BlueskyFeed.astro';
import GitHubFeed from '../components/GitHubFeed.astro';
import profilePhoto from '../assets/nathan-pickard-profile.jpg';
---

<BaseLayout title="Nathan Pickard — Senior Software Engineer">
  <Nav />

  <!-- Hero -->
  <header class="hero">
    <svg
      class="topo"
      aria-hidden="true"
      viewBox="0 0 1240 600"
      preserveAspectRatio="xMidYMid slice"
    >
      <path
        d="M-60,180 Q80,120 200,160 Q320,200 440,140 Q560,80 680,130 Q800,180 920,120 Q1040,60 1160,110 Q1280,160 1400,100"
        fill="none"
        stroke="currentColor"
        stroke-width="1"
        opacity="0.08"></path>
      <path
        d="M-60,240 Q80,180 200,220 Q320,260 440,200 Q560,140 680,190 Q800,240 920,180 Q1040,120 1160,170 Q1280,220 1400,160"
        fill="none"
        stroke="currentColor"
        stroke-width="1"
        opacity="0.08"></path>
      <path
        d="M-60,300 Q80,240 200,280 Q320,320 440,260 Q560,200 680,250 Q800,300 920,240 Q1040,180 1160,230 Q1280,280 1400,220"
        fill="none"
        stroke="currentColor"
        stroke-width="1"
        opacity="0.08"></path>
      <path
        d="M-60,360 Q80,300 200,340 Q320,380 440,320 Q560,260 680,310 Q800,360 920,300 Q1040,240 1160,290 Q1280,340 1400,280"
        fill="none"
        stroke="currentColor"
        stroke-width="1"
        opacity="0.08"></path>
      <path
        d="M-60,420 Q80,360 200,400 Q320,440 440,380 Q560,320 680,370 Q800,420 920,360 Q1040,300 1160,350 Q1280,400 1400,340"
        fill="none"
        stroke="currentColor"
        stroke-width="1"
        opacity="0.08"></path>
      <path
        d="M-60,120 Q80,60 200,100 Q320,140 440,80 Q560,20 680,70 Q800,120 920,60 Q1040,0 1160,50 Q1280,100 1400,40"
        fill="none"
        stroke="currentColor"
        stroke-width="1"
        opacity="0.08"></path>
    </svg>
    <div class="hero-inner">
      <div class="portrait-frame">
        <Image
          src={profilePhoto}
          alt="Nathan Pickard"
          class="portrait"
          loading="eager"
          fetchpriority="high"
          widths={[280, 560]}
          sizes="280px"
        />
      </div>
      <div class="hero-text">
        <h1 class="display">Nathan Pickard</h1>
        <div class="eyebrow eyebrow--below eyebrow--norule">
          Senior Software Engineer
        </div>
        <p class="hero-sub">
          I build web experiences that connect great ideas to the people who
          need them.
        </p>
        <div class="ctas">
          <a href="/resume" class="btn-primary"
            >View Resume <span class="arrow">→</span></a
          >
          <a href="/blog" class="btn-ghost">Read Blog</a>
        </div>
      </div>
    </div>
  </header>

  <!-- Activity Feeds -->
  <section class="feeds-section">
    <div class="feeds-inner">
      <div class="feeds-header">
        <h2 class="feeds-h2">What I've been up to</h2>
      </div>
      <div class="feeds-grid">
        <BlueskyFeed />
        <GitHubFeed />
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--color-border);
    padding: 100px 60px 90px;
  }
  .topo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    color: #ede8d8;
  }
  @media (prefers-reduced-motion: no-preference) {
    .topo path {
      stroke-dasharray: 1400;
      stroke-dashoffset: 1400;
      animation: topoBreath 18s ease-in-out infinite alternate;
    }
    .topo path:nth-child(2) { animation-delay: 3s; }
    .topo path:nth-child(3) { animation-delay: 6s; }
    .topo path:nth-child(4) { animation-delay: 9s; }
    .topo path:nth-child(5) { animation-delay: 12s; }
    .topo path:nth-child(6) { animation-delay: 15s; }
    @keyframes topoBreath {
      to { stroke-dashoffset: 0; }
    }
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 280px auto;
    gap: 60px;
    align-items: center;
    max-width: 920px;
    margin: 0 auto;
    position: relative;
  }
  @media (prefers-reduced-motion: no-preference) {
    .hero-inner {
      animation: heroFadeIn 0.7s ease both;
    }
    @keyframes heroFadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }
  }
  .portrait-frame {
    position: relative;
    width: 280px;
  }
  .portrait-frame::before {
    content: "";
    position: absolute;
    inset: 12px -12px -12px 12px;
    border: 1px solid var(--color-accent);
    opacity: 0.35;
    border-radius: 4px;
    z-index: 0;
  }
  @media (prefers-reduced-motion: no-preference) {
    .portrait-frame::before {
      animation: borderPulse 5s ease-in-out infinite;
    }
    @keyframes borderPulse {
      0%, 100% { opacity: 0.35; }
      50% { opacity: 0.55; }
    }
  }
  .portrait {
    width: 100%;
    aspect-ratio: 4/5;
    object-fit: cover;
    object-position: top;
    border-radius: 4px;
    border: 1px solid var(--color-border);
    display: block;
    position: relative;
    z-index: 1;
  }

  .display {
    font-family: var(--font-cormorant);
    font-weight: 500;
    font-size: clamp(36px, 4vw, 60px);
    line-height: 0.96;
    letter-spacing: var(--tracking-display);
    margin: 0 0 5px;
    color: var(--color-text-heading);
  }
  .eyebrow {
    font-family: var(--font-vollkorn);
    font-style: italic;
    font-weight: 400;
    font-size: 17px;
    color: var(--color-accent);
    margin-bottom: 22px;
    display: inline-flex;
    align-items: center;
    gap: 14px;
  }
  .eyebrow::before {
    content: "";
    width: 32px;
    height: 1px;
    background: var(--color-accent);
    opacity: 0.6;
  }
  .eyebrow--below {
    margin-top: 0;
    margin-bottom: 32px;
    font-size: 22px;
    font-style: normal;
  }
  .eyebrow--norule::before {
    display: none;
  }

  .hero-sub {
    font-family: var(--font-vollkorn);
    font-weight: 300;
    font-size: 19px;
    line-height: 1.55;
    color: #f0ece0;
    max-width: 480px;
    margin: 0 0 36px;
  }
  .ctas {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 28px;
    background: var(--color-accent);
    color: var(--color-bg);
    border-radius: 4px;
    font-family: var(--font-vollkorn);
    font-weight: 700;
    font-size: 15px;
    text-decoration: none;
    transition: opacity 0.2s cubic-bezier(0.4, 0, 0.2, 1), transform 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .btn-primary:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }
  .btn-primary .arrow {
    display: inline-block;
    transition: transform 0.2s;
  }
  .btn-primary:hover .arrow {
    transform: translateX(3px);
  }
  .btn-ghost {
    display: inline-block;
    padding: 14px 28px;
    border: 1px solid var(--color-border);
    color: #ede8d8;
    border-radius: 4px;
    font-family: var(--font-vollkorn);
    font-size: 15px;
    text-decoration: none;
    transition: border-color 0.2s cubic-bezier(0.4, 0, 0.2, 1), color 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .btn-ghost:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  /* ── Feeds ── */
  .feeds-section {
    padding: 50px 60px;
  }
  .feeds-inner {
    max-width: 920px;
    margin: 0 auto;
  }
  .feeds-header {
    margin-bottom: 25px;
  }
  .feeds-h2 {
    font-family: var(--font-cormorant);
    font-weight: 500;
    font-size: clamp(28px, 3.6vw, 44px);
    line-height: 1.05;
    letter-spacing: var(--tracking-sub);
    margin: 0;
    color: var(--color-text-heading);
  }
  .feeds-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: stretch;
  }

  :global(.bluesky-feed),
  :global(.github-feed) {
    display: flex;
    flex-direction: column;
  }
  :global(.github-feed .repo-grid) {
    height: 640px;
    overflow-x: visible;
    overflow-y: auto;
    padding: 0.25rem 0.75rem 0.25rem 0.25rem;
    scrollbar-gutter: stable;
    scrollbar-width: thin;
    scrollbar-color: rgba(137,174,151,0.3) transparent;
  }
  :global(.bluesky-feed .feed-heading),
  :global(.github-feed .feed-heading) {
    color: #ffffff;
  }
  :global(.github-feed .feed-heading svg) {
    filter: invert(1);
  }
  :global(.bluesky-feed .post),
  :global(.github-feed .repo-card) {
    background: #162b1b !important;
    border-color: rgba(137, 174, 151, 0.2) !important;
    box-shadow: none !important;
  }
  :global(.bluesky-feed .post:hover),
  :global(.github-feed .repo-card:hover) {
    border-color: #d4af37 !important;
    box-shadow: 0 4px 20px rgba(212, 175, 55, 0.1) !important;
    transform: translateY(-1px);
  }
  :global(.bluesky-feed .post-link),
  :global(.github-feed .repo-link) {
    color: #ffffff !important;
  }
  :global(.bluesky-feed .post-text) {
    color: #ede8d8 !important;
  }
  :global(.bluesky-feed .post-meta),
  :global(.github-feed .repo-meta) {
    color: #c8e0d0 !important;
  }
  :global(.bluesky-feed .post-date) {
    color: #c8e0d0 !important;
  }
  :global(.github-feed .repo-name) {
    color: #d4af37 !important;
  }
  :global(.github-feed .repo-description) {
    color: #E2EDE6 !important;
  }
  :global(.bluesky-feed .view-all),
  :global(.github-feed .view-all) {
    color: #d4af37 !important;
  }
  :global(.bluesky-feed .feed-scroll) {
    scrollbar-color: rgba(137, 174, 151, 0.3) transparent !important;
  }
  :global(.bluesky-feed .stat-reply),
  :global(.bluesky-feed .stat-repost),
  :global(.bluesky-feed .stat-like) {
    color: #c8e0d0 !important;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .hero {
      padding: 60px 24px;
    }
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 36px;
      max-width: 480px;
    }
    .portrait-frame {
      max-width: 240px;
      width: 100%;
    }
    .feeds-section {
      padding: 60px 24px 80px;
    }
    .feeds-grid {
      grid-template-columns: 1fr;
      gap: 28px;
    }
  }
</style>
