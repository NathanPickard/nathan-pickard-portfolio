---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (
  await getCollection('blog', ({ data }) => data.archived ?? false)
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title={`${SITE_TITLE} — Archived Posts`}
  description={SITE_DESCRIPTION}
>
  <Nav />

  <main class="archived-main">
    <div class="archived-inner">
      <div class="archived-header">
        <h1 class="archived-h1">Archived posts</h1>
      </div>

      {
        posts.length === 0 ? (
          <p class="empty">No archived posts yet.</p>
        ) : (
          <div class="post-list">
            {posts.map((post) => (
              <a href={`/blog/${post.id}/`} class="post-row">
                {post.data.heroImage && (
                  <Image
                    width={120}
                    height={80}
                    src={post.data.heroImage}
                    alt=""
                    class="post-thumb"
                  />
                )}
                <div class="post-info">
                  <div class="post-date">
                    <FormattedDate date={post.data.pubDate} />
                  </div>
                  <div class="post-title">{post.data.title}</div>
                </div>
                <span class="post-arrow">→</span>
              </a>
            ))}
          </div>
        )
      }

      <a href="/blog" class="back-link">← Back to Blog</a>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .archived-main {
    padding: 80px 60px;
  }
  .archived-inner {
    max-width: 1240px;
    margin: 0 auto;
  }
  .archived-header {
    margin-bottom: 48px;
  }
  .archived-h1 {
    font-family: var(--font-eb-garamond);
    font-weight: 400;
    font-variation-settings: 'opsz' 72;
    font-size: clamp(36px, 5vw, 64px);
    line-height: 1;
    letter-spacing: -0.03em;
    margin: 0;
    color: #e2ede6;
  }
  .empty {
    color: #8aae97;
    font-size: 16px;
  }
  .post-list {
    display: flex;
    flex-direction: column;
    margin-bottom: 40px;
    max-width: 700px;
  }
  .post-row {
    display: grid;
    grid-template-columns: 120px 1fr auto;
    gap: 24px;
    align-items: center;
    padding: 20px 0;
    border-top: 1px solid rgba(137, 174, 151, 0.2);
    text-decoration: none;
    color: inherit;
    transition: opacity 0.2s;
  }
  .post-row:last-child {
    border-bottom: 1px solid rgba(137, 174, 151, 0.2);
  }
  .post-row:hover {
    opacity: 0.75;
  }
  .post-thumb {
    width: 120px;
    height: 80px;
    object-fit: cover;
    border-radius: 6px;
    display: block;
    border: 1px solid rgba(137, 174, 151, 0.2);
  }
  .post-date {
    font-family: var(--font-geist-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #e2ede6;
    margin-bottom: 6px;
  }
  .post-title {
    font-family: var(--font-eb-garamond);
    font-weight: 500;
    font-variation-settings: 'opsz' 72;
    font-size: 20px;
    letter-spacing: -0.01em;
    line-height: 1.25;
    color: #ede8d8;
  }
  .post-arrow {
    color: #d4af37;
    font-size: 18px;
    transition: transform 0.2s;
  }
  .post-row:hover .post-arrow {
    transform: translateX(4px);
  }

  .back-link {
    display: inline-block;
    font-size: 14px;
    color: #d4af37;
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .back-link:hover {
    opacity: 0.8;
  }

  @media (max-width: 900px) {
    .archived-main {
      padding: 60px 24px;
    }
    .post-row {
      grid-template-columns: 80px 1fr auto;
      gap: 16px;
    }
    .post-thumb {
      width: 80px;
      height: 56px;
    }
  }
  @media (max-width: 600px) {
    .post-row {
      grid-template-columns: 1fr auto;
    }
    .post-thumb {
      display: none;
    }
  }
</style>
