---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import DarkLayout from '../../layouts/DarkLayout.astro';
import DarkNav from '../../components/DarkNav.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.archived)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<DarkLayout title={`${SITE_TITLE} — Blog`} description={SITE_DESCRIPTION}>
  <DarkNav />

  <main class="blog-main">
    <div class="blog-inner">
      <div class="blog-header">
        <span class="section-label">Blog</span>
        <h1 class="blog-h1">What I'm thinking, building, and reading</h1>
      </div>

      <div class="blog-grid">
        {
          posts.map((post) => (
            <a href={`/blog/${post.id}/`} class="blog-card">
              {post.data.heroImage && (
                <Image
                  width={720}
                  height={360}
                  src={post.data.heroImage}
                  alt=""
                  class="card-image"
                />
              )}
              <div class="card-body">
                <p class="card-date">
                  <FormattedDate date={post.data.pubDate} />
                </p>
                <h2 class="card-title">{post.data.title}</h2>
                {post.data.description && (
                  <p class="card-desc">{post.data.description}</p>
                )}
              </div>
            </a>
          ))
        }
      </div>

      <a href="/blog/archived" class="archived-link">View archived posts →</a>
    </div>
  </main>

  <Footer />
</DarkLayout>

<style>
  .blog-main {
    padding: 80px 60px;
  }
  .blog-inner {
    max-width: 1240px;
    margin: 0 auto;
  }
  .blog-header {
    margin-bottom: 48px;
  }
  .section-label {
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #e2ede6;
    display: block;
    margin-bottom: 16px;
  }
  .blog-h1 {
    font-family: 'Fraunces', serif;
    font-weight: 400;
    font-variation-settings: 'opsz' 72;
    font-size: clamp(36px, 5vw, 64px);
    line-height: 1;
    letter-spacing: -0.03em;
    margin: 0;
    color: #e2ede6;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 40px;
  }
  .blog-card {
    display: flex;
    flex-direction: column;
    background: #162b1b;
    border: 1px solid rgba(137, 174, 151, 0.2);
    border-radius: 10px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition:
      border-color 0.2s,
      box-shadow 0.2s,
      transform 0.15s;
  }
  .blog-card:hover {
    border-color: #d4af37;
    box-shadow: 0 8px 32px rgba(200, 120, 64, 0.1);
    transform: translateY(-2px);
  }
  .card-image {
    width: 100%;
    height: 180px;
    object-fit: cover;
    display: block;
    margin: 0;
    border-radius: 0;
  }
  .card-body {
    padding: 1.25rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .card-date {
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #e2ede6;
    margin: 0 0 8px;
  }
  .card-title {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-variation-settings: 'opsz' 72;
    font-size: 19px;
    letter-spacing: -0.01em;
    line-height: 1.25;
    color: #ede8d8;
    margin: 0 0 10px;
  }
  .card-desc {
    font-size: 14px;
    color: #e2ede6;
    line-height: 1.6;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }
  .archived-link {
    font-size: 14px;
    color: #d4af37;
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .archived-link:hover {
    opacity: 0.8;
  }

  @media (max-width: 900px) {
    .blog-main {
      padding: 60px 24px;
    }
    .blog-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 600px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
