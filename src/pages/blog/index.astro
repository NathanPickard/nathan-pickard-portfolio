---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog', ({ data }) => !data.archived)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title={`${SITE_TITLE} — Blog`} description={SITE_DESCRIPTION}>
  <Nav />

  <main class="blog-main">
    <div class="blog-inner">
      <header class="blog-header" data-reveal>
        <h1 class="blog-h1">What I'm thinking, building, and reading</h1>
      </header>

      <ul class="post-list" data-reveal-stagger>
        {
          posts.map((post) => (
            <li class="post-row" data-reveal>
              <a href={`/blog/${post.id}/`} class="post-link">
                <div class="post-media">
                  {post.data.heroImage ? (
                    <Image
                      width={1600}
                      height={600}
                      src={post.data.heroImage}
                      alt=""
                      class="post-image"
                    />
                  ) : (
                    <div class="post-image post-image--placeholder" />
                  )}
                </div>
                <div class="post-content">
                  <time class="post-date">
                    <FormattedDate date={post.data.pubDate} />
                  </time>
                  <h2 class="post-title">{post.data.title}</h2>
                  {post.data.description && (
                    <p class="post-desc">{post.data.description}</p>
                  )}
                </div>
              </a>
            </li>
          ))
        }
      </ul>

      <a href="/blog/archived" class="archived-link">View archived posts →</a>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .blog-main {
    padding: 80px 60px;
  }
  .blog-inner {
    max-width: 800px;
    margin: 0 auto;
  }
  .blog-header {
    margin-bottom: 48px;
  }
  .blog-h1 {
    font-family: var(--font-eb-garamond);
    font-weight: 400;
    font-variation-settings: 'opsz' 72;
    font-size: clamp(28px, 3.6vw, 44px);
    line-height: 1.05;
    letter-spacing: var(--tracking-heading);
    margin: 0;
    color: #f7f2e4;
  }

  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 45px;
  }

  .post-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .post-link:hover .post-title,
  .post-link:hover .post-desc {
    color: #d4af37;
  }
  .post-link:hover .post-image {
    transform: scale(1.015);
  }

  .post-media {
    overflow: hidden;
    border-radius: 6px;
    aspect-ratio: 7 / 2;
    background: #162b1b;
    margin-bottom: 20px;
  }
  .post-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .post-image--placeholder {
    background: linear-gradient(135deg, #162b1b 0%, #1f3a26 100%);
  }

  .post-content {
    display: flex;
    flex-direction: column;
    gap: 10px;
    max-width: 820px;
  }
  .post-date {
    font-family: var(--font-dm-sans);
    font-size: 14px;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: #f7f2e4;
    opacity: 0.7;
  }
  .post-title {
    font-family: var(--font-eb-garamond);
    font-weight: 500;
    font-variation-settings: 'opsz' 72;
    font-size: clamp(22px, 2.4vw, 30px);
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin: 0;
    color: #f7f2e4;
    transition: color 0.2s ease;
  }
  .post-desc {
    font-family: var(--font-inter);
    font-size: 16px;
    line-height: 1.6;
    color: #f7f2e4;
    opacity: 0.85;
    margin: 0;
    transition: color 0.2s ease;
  }
  .archived-link {
    display: inline-block;
    margin-top: 64px;
    font-size: 18px;
    color: #d4af37;
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .archived-link:hover {
    opacity: 0.8;
  }

  @media (max-width: 900px) {
    .blog-main {
      padding: 60px 24px;
    }
    .post-list {
      gap: 28px;
    }
  }
</style>
