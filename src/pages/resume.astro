---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import resume from '../data/resume.json';
import { Icon } from 'astro-icon/components';
---

<BaseLayout title="Resume — Nathan Pickard" description="Senior Software Engineer with 6+ years shipping consumer-facing software in fintech, wellness, and healthtech.">
  <Nav />

  <main class="resume-main">
    <div class="resume-inner">

      <!-- Page header -->
      <div class="resume-page-header">
        <div>
          <span class="section-label">Resume</span>
          <h1 class="resume-name">{resume.basics.name}</h1>
          <p class="resume-label">{resume.basics.label}</p>
          <p class="resume-contact">
            {resume.basics.location}
            <span class="sep">·</span>
            <a href={`mailto:${resume.basics.email}`}>{resume.basics.email}</a>
            <span class="sep">·</span>
            <a href="https://linkedin.com/in/nathanpickard" target="_blank" rel="noopener noreferrer">LinkedIn</a>
            <span class="sep">·</span>
            <a href="https://github.com/nathanpickard" target="_blank" rel="noopener noreferrer">GitHub</a>
          </p>
        </div>
        <a href="/resume.pdf" class="download-btn">
          <Icon name="mdi:download" size={16} aria-hidden="true" />
          Download PDF
        </a>
      </div>

      <!-- Summary -->
      <section class="resume-section">
        <h2 class="section-heading">Career Summary</h2>
        <p class="summary-text">{resume.basics.summary}</p>
      </section>

      <!-- Skills -->
      <section class="resume-section">
        <h2 class="section-heading">Skills</h2>
        <div class="skills-list">
          {resume.skills.map(skill => (
            <div class="skill-row">
              <span class="skill-name">{skill.name}</span>
              <span class="skill-keywords">{skill.keywords.join(', ')}</span>
            </div>
          ))}
        </div>
      </section>

      <!-- Education -->
      {resume.education && resume.education.length > 0 && (
        <section class="resume-section">
          <h2 class="section-heading">Education</h2>
          {resume.education.map(edu => (
            <div class="edu-row">
              <span class="edu-institution">{edu.institution}</span>
              <span class="edu-degree">{edu.studyType} {edu.area}{edu.status ? ` — ${edu.status}` : ''}</span>
            </div>
          ))}
        </section>
      )}

      <!-- Experience -->
      <section class="resume-section">
        <h2 class="section-heading">Experience</h2>
        <div class="work-list">
          {resume.work.map(job => (
            <div class="work-item">
              <div class="work-header">
                <div class="work-header-left">
                  <span class="work-company">{job.company}</span>
                  <span class="work-position">{job.position}</span>
                  {job.description && <span class="work-desc">{job.description}</span>}
                </div>
                <span class="work-dates">{job.startDate} – {job.endDate}</span>
              </div>
              <ul class="work-highlights">
                {job.highlights.map(h => (
                  <li>{h}</li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </section>

      <!-- Activities -->
      {resume.activities && resume.activities.length > 0 && (
        <section class="resume-section">
          <h2 class="section-heading">Activities & Community</h2>
          <ul class="activities-list">
            {resume.activities.map(a => <li>{a}</li>)}
          </ul>
        </section>
      )}

    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .resume-main {
    padding: 80px 60px;
  }
  .resume-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  /* Page header */
  .resume-page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 24px;
    padding-bottom: 40px;
    border-bottom: 1px solid rgba(137,174,151,0.2);
    margin-bottom: 48px;
  }
  .section-label {
    font-family: var(--font-geist-mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #E2EDE6;
    display: block;
    margin-bottom: 12px;
  }
  .resume-name {
    font-family: var(--font-fraunces);
    font-weight: 400;
    font-variation-settings: "opsz" 144;
    font-size: clamp(36px, 5vw, 56px);
    line-height: 1.0;
    letter-spacing: -0.03em;
    color: #E2EDE6;
    margin: 0 0 8px;
  }
  .resume-label {
    font-size: 16px;
    color: #E2EDE6;
    margin: 0 0 10px;
  }
  .resume-contact {
    font-family: var(--font-geist-mono);
    font-size: 12px;
    color: #c8e0d0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    align-items: center;
  }
  .resume-contact a {
    color: #D4AF37;
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .resume-contact a:hover { opacity: 0.8; }
  .sep { color: rgba(137,174,151,0.4); }

  .download-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 22px;
    background: #D4AF37;
    color: #0D1C10;
    border-radius: 4px;
    font-weight: 600;
    font-size: 14px;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: opacity 0.2s;
  }
  .download-btn:hover { opacity: 0.85; }

  /* Sections */
  .resume-section {
    margin-bottom: 48px;
    padding-bottom: 48px;
    border-bottom: 1px solid rgba(137,174,151,0.2);
  }
  .resume-section:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }
  .section-heading {
    font-family: var(--font-fraunces);
    font-weight: 500;
    font-variation-settings: "opsz" 72;
    font-size: 22px;
    letter-spacing: -0.01em;
    color: #EDE8D8;
    margin: 0 0 20px;
  }

  /* Summary */
  .summary-text {
    font-size: 15px;
    line-height: 1.75;
    color: #E2EDE6;
    margin: 0;
  }

  /* Skills */
  .skills-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .skill-row {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 16px;
    font-size: 14px;
    line-height: 1.6;
  }
  .skill-name {
    font-family: var(--font-geist-mono);
    font-size: 12px;
    color: #E2EDE6;
    font-weight: 500;
    padding-top: 1px;
  }
  .skill-keywords {
    color: #EDE8D8;
  }

  /* Education */
  .edu-row {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .edu-institution {
    font-size: 15px;
    font-weight: 600;
    color: #EDE8D8;
  }
  .edu-degree {
    font-size: 14px;
    color: #E2EDE6;
  }

  /* Experience */
  .work-list {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }
  .work-item {
    padding-bottom: 40px;
    border-bottom: 1px solid rgba(137,174,151,0.1);
  }
  .work-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
  .work-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    margin-bottom: 14px;
  }
  .work-header-left {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .work-company {
    font-family: var(--font-fraunces);
    font-weight: 600;
    font-variation-settings: "opsz" 72;
    font-size: 20px;
    letter-spacing: -0.01em;
    color: #E2EDE6;
  }
  .work-position {
    font-size: 14px;
    font-weight: 600;
    color: #E2EDE6;
  }
  .work-desc {
    font-size: 13px;
    font-family: var(--font-geist-mono);
    color: #c8e0d0;
  }
  .work-dates {
    font-family: var(--font-geist-mono);
    font-size: 12px;
    color: #c8e0d0;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .work-highlights {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .work-highlights li {
    font-size: 14px;
    line-height: 1.65;
    color: #E2EDE6;
    padding-left: 16px;
    position: relative;
  }
  .work-highlights li::before {
    content: '·';
    position: absolute;
    left: 0;
    color: #D4AF37;
    font-weight: 700;
  }

  /* Activities */
  .activities-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .activities-list li {
    font-size: 14px;
    line-height: 1.65;
    color: #E2EDE6;
    padding-left: 16px;
    position: relative;
  }
  .activities-list li::before {
    content: '·';
    position: absolute;
    left: 0;
    color: #D4AF37;
    font-weight: 700;
  }

  @media (max-width: 900px) {
    .resume-main { padding: 60px 24px; }
    .resume-page-header { flex-direction: column; gap: 20px; }
    .skill-row { grid-template-columns: 1fr; gap: 4px; }
    .work-header { flex-direction: column; gap: 4px; }
    .work-dates { align-self: flex-start; }
  }
</style>
