---
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import BaseHead from '../components/BaseHead.astro';
import resume from '../data/resume.json';
import { SITE_TITLE, SITE_DESCRIPTION } from '@/consts';
import { Icon } from 'astro-icon/components';
---

<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      .prose {
        width: 800px;
        max-width: calc(100% - 2em);
        margin: auto;
        padding: 1em;
        color: rgb(var(--gray-dark));
      }

      .title {
        text-align: center;
        line-height: 1;
      }
      .resume-section {
        padding: 2rem 0;
      }
      .download-btn {
        background-color: var(--accent);
        color: white;
      }
      .download-btn:hover {
        background-color: var(--accent-dark);
        color: white;
      }

      @media (max-width: 720px) {
        .prose {
          padding: 1rem;
          max-width: 100%;
        }

        .job-header {
          flex-direction: column;
          align-items: flex-start;
          gap: 0.25rem;
        }

        .download-btn {
          display: flex;
          justify-content: center;
          min-height: 44px;
          min-width: 44px;
          align-items: center;
          margin: 0 auto;
        }
      }
    </style>
  </head>

  <body>
    <Header />
    <main class="max-w-3xl mx-auto px-4 py-12">
      <div class="title">
        <h1>Resume</h1>
        <hr />
        <div class="resume-section">
          <a
            href="/resume.pdf"
            class="download-btn inline-flex items-center gap-1.5 px-4 py-2 rounded text-sm no-underline whitespace-nowrap shrink-0"
          >
            <Icon name="mdi:download" size={16} />
            Download PDF
          </a>
        </div>
      </div>

      <div class="flex justify-between items-start">
        <div>
          <h1 class="text-3xl font-bold">{resume.basics.name}</h1>
          <p class="text-gray-500">{resume.basics.label}</p>
          <p class="text-gray-500 text-sm">{resume.basics.location} · {resume.basics.phone} · {resume.basics.email}</p>
        </div>
      </div>

      <section class="mt-6">
        <h4 class="font-semibold border-b pb-1 mb-3">Career Summary</h4>
        <p class="text-sm leading-relaxed">{resume.basics.summary}</p>
      </section>

      <section class="mt-8">
        <h4 class="font-semibold border-b pb-1 mb-4">Skills</h4>
        {
          resume.skills.map((skill) => (
            <div class="mb-2 text-sm">
              <strong>{skill.name}:</strong> {skill.keywords.join(', ')}
            </div>
          ))
        }
      </section>

      {resume.education && (
        <section class="mt-8">
          <h4 class="font-semibold border-b pb-1 mb-4">Education</h4>
          {resume.education.map((edu) => (
            <div class="text-sm">
              <strong>{edu.institution}</strong> – {edu.studyType} {edu.area}{edu.status ? `, ${edu.status}` : ''}
            </div>
          ))}
        </section>
      )}

      <section class="mt-8">
        <h4 class="font-semibold border-b pb-1 mb-4">Experience</h4>
        {
          resume.work.map((job) => (
            <div class="mb-6">
              <div class="flex justify-between job-header">
                <div>
                  <strong>{job.company}</strong> | <span>{job.position}</span>
                </div>
                <span class="text-gray-500 text-sm shrink-0">
                  {job.startDate} – {job.endDate}
                </span>
              </div>
              {job.description && (
                <div class="text-gray-500 text-sm italic">{job.description}</div>
              )}
              <ul class="mt-2 list-disc list-outside text-sm space-y-1 pl-5">
                {job.highlights.map((h) => (
                  <li>{h}</li>
                ))}
              </ul>
            </div>
          ))
        }
      </section>

      {resume.activities && (
        <section class="mt-8">
          <h4 class="font-semibold border-b pb-1 mb-4">Activities & Community</h4>
          <ul class="list-disc list-outside text-sm space-y-1 pl-5">
            {resume.activities.map((activity) => (
              <li>{activity}</li>
            ))}
          </ul>
        </section>
      )}
    </main>
    <Footer />
  </body>
</html>
