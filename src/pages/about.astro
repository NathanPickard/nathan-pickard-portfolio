---
import { Icon } from 'astro-icon/components';
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="About — Nathan Pickard"
  description="Senior Full-Stack Engineer based in Portland, OR. 6+ years building at the intersection of craft and scale."
>
  <Nav />

  <main class="about-main">
    <div class="about-inner">
      <!-- Header: full width -->
      <div class="about-header" data-reveal>
        <h1 class="about-h1">
          Craft, curiosity, and coffee<br />- A bit about me
        </h1>
      </div>

      <!-- Body: bio left, card right -->
      <div class="about-body-row" data-reveal>
        <div class="about-body">
          <p class="bio">
            6+ years shipping consumer-facing software at the intersection of
            craft and scale. Most of that time in fintech, where good product
            decisions help folks take control of their financial health with
            confidence. Currently in Portland, chasing good trails and better
            coffee.
          </p>
          <p class="bio">
            I care about the craft and the purpose. Not just shipping features
            but understanding why they matter. I read engineering blogs in the
            morning and usually over a very good cup of pour-over.
          </p>
          <div class="about-ctas">
            <a href="/resume" class="btn-primary">View Resume →</a>
            <a href="/work" class="btn-ghost">See my work</a>
          </div>
        </div>

        <div class="pnw-card" data-reveal data-reveal-delay="120">
          <div class="pnw-title">Life outside the IDE</div>
          {
            [
              ['mdi:coffee', 'Coffee aficionado'],
              ['mdi:hiking', 'Hiking/Exploring'],
              ['mdi:pot-steam', 'Home cook, BBQ enthusiast'],
              ['mdi:pine-tree', 'Portland local, PNW-based'],
            ].map(([icon, text]) => (
              <div class="pnw-item">
                <Icon
                  name={icon}
                  size={25}
                  aria-hidden="true"
                  class="pnw-icon"
                />
                <span>{text}</span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .about-main {
    padding: 80px 60px;
  }
  .about-inner {
    max-width: 1000px;
    margin: 0 auto;
  }

  /* Full-width header */
  .about-header {
    margin-bottom: 40px;
  }
  .about-h1 {
    font-family: var(--font-eb-garamond);
    font-weight: 400;
    font-variation-settings: 'opsz' 72;
    font-size: clamp(28px, 3.6vw, 44px);
    line-height: 1.05;
    letter-spacing: var(--tracking-heading);
    margin: 0;
    color: #e2ede6;
  }

  /* Bio + card side by side */
  .about-body-row {
    display: grid;
    grid-template-columns: 1fr 260px;
    gap: 60px;
    align-items: start;
  }
  .about-body {
    min-width: 0;
  }
  .bio {
    font-size: 18px;
    line-height: 1.75;
    color: #f0ece0;
    margin: 0 0 18px;
  }
  .about-ctas {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 32px;
  }
  .btn-primary {
    display: inline-block;
    padding: 13px 26px;
    background: #d4af37;
    color: #0d1c10;
    border-radius: 4px;
    font-weight: 600;
    font-size: 16px;
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .btn-primary:hover {
    opacity: 0.85;
  }
  .btn-ghost {
    display: inline-block;
    padding: 13px 26px;
    border: 1px solid rgba(137, 174, 151, 0.2);
    color: #ede8d8;
    border-radius: 4px;
    font-size: 16px;
    text-decoration: none;
    transition: border-color 0.2s;
  }
  .btn-ghost:hover {
    border-color: #8aae97;
  }

  /* PNW card */
  .pnw-card {
    background: #162b1b;
    border: 1px solid rgba(137, 174, 151, 0.2);
    border-radius: 8px;
    padding: 20px;
  }
  .pnw-title {
    font-size: 17px;
    /* text-transform: uppercase; */
    letter-spacing: 0.1em;
    color: #e2ede6;
    /* font-family: var(--font-dm-sans); */
    margin-bottom: 14px;
    font-weight: 500;
  }
  .pnw-item {
    display: flex;
    gap: 12px;
    padding: 8px 0;
    border-bottom: 1px solid rgba(137, 174, 151, 0.2);
    font-size: 15px;
    color: #e2ede6;
    align-items: center;
  }
  .pnw-item:last-child {
    border-bottom: 0;
  }
  .pnw-icon {
    color: #8aae97;
    flex-shrink: 0;
  }

  @media (max-width: 900px) {
    .about-main {
      padding: 60px 24px;
    }
    .about-body-row {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .pnw-card {
      width: fit-content;
      min-width: 280px;
    }
  }
</style>
