---
import { Icon } from 'astro-icon/components';
import DarkLayout from '../layouts/DarkLayout.astro';
import DarkNav from '../components/DarkNav.astro';
import Footer from '../components/Footer.astro';

---

<DarkLayout
  title="About — Nathan Pickard"
  description="Senior Full-Stack Engineer based in Portland, OR. 6+ years building at the intersection of craft and scale."
>
  <DarkNav />

  <main class="about-main">
    <div class="about-inner">

      <!-- Header: full width -->
      <div class="about-header">
        <span class="section-label">About</span>
        <h1 class="about-h1">
          Craft, curiosity, and coffee<br />- A bit about me
        </h1>
      </div>

      <!-- Body: bio left, card right -->
      <div class="about-body-row">
        <div class="about-body">
          <p class="bio">
            Six years shipping consumer-facing software at the intersection of
            craft and scale. Most of that time in fintech, where good product
            decisions help folks take control of their financial health with
            confidence. Currently in Portland, chasing good trails and better
            coffee.
          </p>
          <p class="bio">
            I care about the craft. Not just shipping features but understanding
            why they matter. I read engineering blogs in the morning and usually
            over a very good cup of pour-over.
          </p>
          <div class="about-ctas">
            <a href="/resume" class="btn-primary">View Resume →</a>
            <a href="/work" class="btn-ghost">See my work</a>
          </div>
        </div>

        <div class="pnw-card">
          <div class="pnw-title">Life outside the IDE</div>
          {
            [
              ['mdi:coffee',    'Coffee aficionado'],
              ['mdi:hiking',    'Hiking/Exploring'],
              ['mdi:pot-steam', 'Home cook, BBQ enthusiast'],
              ['mdi:pine-tree', 'Portland local, PNW-based'],
            ].map(([icon, text]) => (
              <div class="pnw-item">
                <Icon name={icon} size={16} aria-hidden="true" class="pnw-icon" />
                <span>{text}</span>
              </div>
            ))
          }
        </div>
      </div>

    </div>
  </main>

  <Footer />
</DarkLayout>

<style>
  .about-main {
    padding: 80px 60px;
  }
  .about-inner {
    max-width: 1000px;
    margin: 0 auto;
  }
  .section-label {
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #8aae97;
    display: block;
    margin-bottom: 16px;
  }

  /* Full-width header */
  .about-header {
    margin-bottom: 40px;
  }
  .about-h1 {
    font-family: 'Fraunces', serif;
    font-weight: 400;
    font-variation-settings: 'opsz' 72;
    font-size: clamp(32px, 4vw, 52px);
    line-height: 1.05;
    letter-spacing: -0.025em;
    margin: 0;
    color: #ede8d8;
  }

  /* Bio + card side by side */
  .about-body-row {
    display: grid;
    grid-template-columns: 1fr 260px;
    gap: 60px;
    align-items: start;
  }
  .about-body {
    min-width: 0;
  }
  .bio {
    font-size: 16px;
    line-height: 1.75;
    color: #ede8d8;
    margin: 0 0 18px;
  }
  .about-ctas {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 32px;
  }
  .btn-primary {
    display: inline-block;
    padding: 13px 26px;
    background: #d4af37;
    color: #0d1c10;
    border-radius: 4px;
    font-weight: 600;
    font-size: 14px;
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .btn-primary:hover { opacity: 0.85; }
  .btn-ghost {
    display: inline-block;
    padding: 13px 26px;
    border: 1px solid rgba(137, 174, 151, 0.2);
    color: #ede8d8;
    border-radius: 4px;
    font-size: 14px;
    text-decoration: none;
    transition: border-color 0.2s;
  }
  .btn-ghost:hover { border-color: #8aae97; }

  /* PNW card */
  .pnw-card {
    background: #162b1b;
    border: 1px solid rgba(137, 174, 151, 0.2);
    border-radius: 8px;
    padding: 20px;
  }
  .pnw-title {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: #e2ede6;
    font-family: 'Geist Mono', monospace;
    margin-bottom: 14px;
    font-weight: 500;
  }
  .pnw-item {
    display: flex;
    gap: 12px;
    padding: 8px 0;
    border-bottom: 1px solid rgba(137, 174, 151, 0.2);
    font-size: 13px;
    color: #e2ede6;
    align-items: center;
  }
  .pnw-item:last-child { border-bottom: 0; }
  .pnw-icon {
    color: #8aae97;
    flex-shrink: 0;
  }

  @media (max-width: 900px) {
    .about-main { padding: 60px 24px; }
    .about-body-row {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .pnw-card {
      width: fit-content;
      min-width: 280px;
    }
  }
</style>
