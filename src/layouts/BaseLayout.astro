---
import type { ImageMetadata } from 'astro';
import { Font } from 'astro:assets';
import { ClientRouter } from 'astro:transitions';
import FallbackImage from '../assets/blog-placeholder-2.jpg';
import dougFirRings from '../assets/doug-fir-rings.png';
import { SITE_TITLE } from '../consts';

interface Props {
  title: string;
  description?: string;
  image?: ImageMetadata;
}
const {
  title,
  description = "Senior Full-Stack Engineer based in Portland, OR.",
  image = FallbackImage,
} = Astro.props;

// Astro.site is undefined in test contexts (AstroContainer); skip absolute URLs there.
const canonicalURL = Astro.site ? new URL(Astro.url.pathname, Astro.site) : null;
const socialImage = Astro.site ? new URL(image.src, Astro.site) : null;
const rssURL = Astro.site ? new URL('rss.xml', Astro.site) : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />

    {canonicalURL && <link rel="canonical" href={canonicalURL} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    {rssURL && (
      <link
        rel="alternate"
        type="application/rss+xml"
        title={SITE_TITLE}
        href={rssURL}
      />
    )}

    <Font cssVariable="--font-cormorant" />
    <Font cssVariable="--font-vollkorn" />
    <Font cssVariable="--font-eb-garamond" />
    <Font cssVariable="--font-inter" />
    <Font cssVariable="--font-dm-sans" />

    <ClientRouter />

    {canonicalURL && socialImage && (
      <>
        <!-- Open Graph -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={socialImage} />

        <!-- Twitter -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:url" content={canonicalURL} />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={socialImage} />
      </>
    )}
  </head>
  <body>
    <svg
      class="site-topo"
      aria-hidden="true"
      viewBox="0 0 768 1024"
      preserveAspectRatio="xMidYMid meet"
    >
      <defs>
        <filter id="site-topo-green-tint" color-interpolation-filters="sRGB">
          <feColorMatrix
            type="matrix"
            values="0 0 0 0 0.537
                    0 0 0 0 0.682
                    0 0 0 0 0.592
                    -1 -1 -1 0 1"
          />
        </filter>
      </defs>
      <image
        href={dougFirRings.src}
        width="768"
        height="1024"
        preserveAspectRatio="xMidYMid slice"
        filter="url(#site-topo-green-tint)"
        opacity="0.09"
      />
    </svg>
    <div class="page-wrapper">
      <slot />
    </div>
  </body>
</html>

<style is:global>
  :root {
    /* ── Type scale ── */
    --text-display: clamp(56px, 6.2vw, 96px);
    --text-h1: clamp(32px, 4.5vw, 56px);
    --text-h2: clamp(38px, 4.4vw, 60px);
    --text-h3: 22px;
    /* ── Letter-spacing ── */
    --tracking-display: -0.022em;
    --tracking-heading: -0.018em;
    --tracking-sub: -0.018em;
    --tracking-label: 0;
    /* ── Colors ── */
    --color-bg: #0D1C10;
    --color-text: #EDE8D8;
    --color-text-muted: #c8e0d0;
    --color-text-heading: #E2EDE6;
    --color-accent: #d4af37;
    --color-border: rgba(137, 174, 151, 0.2);
    --color-card: #162b1b;
    --color-green: #8aae97;
    /* ── Spacing ── */
    --pad-v: 80px;
    --pad-h: 60px;
  }

  *, *::before, *::after { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; height: 100%; }
  body {
    font-family: var(--font-vollkorn);
    font-weight: 400;
    -webkit-font-smoothing: antialiased;
    background: var(--color-bg);
    color: var(--color-text);
    min-height: 100vh;
  }
  .page-wrapper {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    position: relative;
    z-index: 0;
  }
  .site-topo {
    position: fixed;
    top: -160px;
    right: 200px;
    height: 1700px;
    aspect-ratio: 768 / 1024;
    pointer-events: none;
    z-index: -1;
  }
  @media (max-width: 900px) {
    .site-topo {
      top: 50%;
      left: 50%;
      right: auto;
      height: 100vh;
      transform: translate(-50%, -50%);
    }
  }
  .page-wrapper > main {
    flex: 1;
  }
  a { color: inherit; }
  img { max-width: 100%; height: auto; }

  /* Scroll reveal system */
  @media (prefers-reduced-motion: no-preference) {
    [data-reveal] {
      opacity: 0;
      transition: opacity 0.65s ease;
    }
    [data-reveal].is-visible {
      opacity: 1;
    }
  }

  /* Keyboard focus ring */
  :focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
    border-radius: 3px;
  }
</style>

<script>
  function initReveal() {
    // Apply manual delays from data-reveal-delay attribute (value in ms)
    document.querySelectorAll<HTMLElement>('[data-reveal][data-reveal-delay]').forEach(el => {
      const delay = parseInt(el.getAttribute('data-reveal-delay') ?? '', 10);
      if (!isNaN(delay) && delay >= 0) el.style.transitionDelay = `${delay}ms`;
    });

    // Apply stagger delays to direct [data-reveal] children of [data-reveal-stagger] containers
    // Skip children that have an explicit data-reveal-delay so manual delays are not clobbered
    document.querySelectorAll('[data-reveal-stagger]').forEach(container => {
      const children = Array.from(container.children).filter(
        child => child.hasAttribute('data-reveal')
      ) as HTMLElement[];
      children.forEach((child, i) => {
        if (!child.hasAttribute('data-reveal-delay')) {
          child.style.transitionDelay = `${Math.min(i, 5) * 80}ms`;
        }
      });
    });

    // Observe all [data-reveal] elements that haven't already been revealed
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            (entry.target as HTMLElement).classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );

    document.querySelectorAll('[data-reveal]').forEach(el => {
      if (!el.classList.contains('is-visible')) observer.observe(el);
    });
  }

  // Fires on initial load and after each View Transition navigation
  document.addEventListener('astro:page-load', initReveal);
</script>
