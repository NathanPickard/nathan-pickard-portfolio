---
import type { ImageMetadata } from 'astro';
import { Font } from 'astro:assets';
import FallbackImage from '../assets/blog-placeholder-1.jpg';
import { SITE_TITLE } from '../consts';

interface Props {
  title: string;
  description?: string;
  image?: ImageMetadata;
}
const {
  title,
  description = "Senior Full-Stack Engineer based in Portland, OR.",
  image = FallbackImage,
} = Astro.props;

// Astro.site is undefined in test contexts (AstroContainer); skip absolute URLs there.
const canonicalURL = Astro.site ? new URL(Astro.url.pathname, Astro.site) : null;
const socialImage = Astro.site ? new URL(image.src, Astro.site) : null;
const rssURL = Astro.site ? new URL('rss.xml', Astro.site) : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />

    {canonicalURL && <link rel="canonical" href={canonicalURL} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    {rssURL && (
      <link
        rel="alternate"
        type="application/rss+xml"
        title={SITE_TITLE}
        href={rssURL}
      />
    )}

    <Font cssVariable="--font-cormorant" />
    <Font cssVariable="--font-vollkorn" />
    <Font cssVariable="--font-eb-garamond" />
    <Font cssVariable="--font-inter" />
    <Font cssVariable="--font-geist-mono" />

    {canonicalURL && socialImage && (
      <>
        <!-- Open Graph -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={socialImage} />

        <!-- Twitter -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:url" content={canonicalURL} />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={socialImage} />
      </>
    )}
  </head>
  <body>
    <div class="page-wrapper">
      <slot />
    </div>
  </body>
</html>

<style is:global>
  :root {
    /* ── Type scale ── */
    --text-display: clamp(56px, 6.2vw, 96px);
    --text-h1: clamp(32px, 4.5vw, 56px);
    --text-h2: clamp(38px, 4.4vw, 60px);
    --text-h3: 22px;
    /* ── Letter-spacing ── */
    --tracking-display: -0.022em;
    --tracking-heading: -0.018em;
    --tracking-sub: -0.018em;
    --tracking-label: 0;
    /* ── Colors ── */
    --color-bg: #0D1C10;
    --color-text: #EDE8D8;
    --color-text-muted: #c8e0d0;
    --color-text-heading: #E2EDE6;
    --color-accent: #d4af37;
    --color-border: rgba(137, 174, 151, 0.2);
    --color-card: #162b1b;
    --color-green: #8aae97;
    /* ── Spacing ── */
    --pad-v: 80px;
    --pad-h: 60px;
  }

  *, *::before, *::after { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; height: 100%; }
  body {
    font-family: var(--font-vollkorn);
    font-weight: 400;
    -webkit-font-smoothing: antialiased;
    background: var(--color-bg);
    color: var(--color-text);
    min-height: 100vh;
  }
  .page-wrapper {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }
  .page-wrapper > main {
    flex: 1;
  }
  a { color: inherit; }
  img { max-width: 100%; height: auto; }
</style>
