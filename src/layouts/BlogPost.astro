---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<BaseLayout title={title} description={description} image={heroImage}>
  <Nav />

  <main class="post-main">
    {
      heroImage && (
        <div class="hero-image">
          <Image
            width={1240}
            height={560}
            src={heroImage}
            alt=""
            class="hero-img"
          />
        </div>
      )
    }

    <div class="post-inner">
      <div class="post-header" data-reveal>
        <div class="post-date">
          <FormattedDate date={pubDate} />
          {
            updatedDate && (
              <span class="updated">
                {' '}
                · Updated <FormattedDate date={updatedDate} />
              </span>
            )
          }
        </div>
        <h1 class="post-title">{title}</h1>
        {description && <p class="post-desc">{description}</p>}
        <div class="post-divider"></div>
      </div>

      <div class="prose">
        <slot />
      </div>

      <a href="/blog" class="back-link">← Back to Blog</a>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .post-main {
    max-width: 100%;
  }
  .hero-image {
    width: 100%;
    max-height: 480px;
    overflow: hidden;
  }
  .hero-img {
    width: 100%;
    height: 480px;
    object-fit: cover;
    display: block;
    border-radius: 0;
    margin: 0;
    filter: brightness(0.85);
  }
  .post-inner {
    max-width: 760px;
    margin: 0 auto;
    padding: 60px 24px 80px;
  }
  .post-header {
    margin-bottom: 40px;
  }
  .post-date {
    font-family: var(--font-geist-mono);
    font-size: 12px;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: #e2ede6;
    margin-bottom: 16px;
  }
  .updated {
    color: #a8c8b4;
  }
  .post-title {
    font-family: var(--font-eb-garamond);
    font-weight: 400;
    font-variation-settings: 'opsz' 144;
    font-size: var(--text-h1);
    line-height: 1.05;
    letter-spacing: var(--tracking-heading);
    color: #e2ede6;
    margin: 0 0 16px;
  }
  .post-desc {
    font-size: 18px;
    line-height: 1.6;
    color: #e2ede6;
    margin: 0 0 24px;
  }
  .post-divider {
    height: 1px;
    background: rgba(137, 174, 151, 0.2);
    margin-top: 8px;
  }

  /* Prose styles */
  .prose {
    font-family: var(--font-inter);
    font-size: 17px;
    line-height: 1.8;
    color: #ede8d8;
  }
  .prose :global(h2) {
    font-family: var(--font-eb-garamond);
    font-weight: 500;
    font-variation-settings: 'opsz' 72;
    font-size: 28px;
    letter-spacing: -0.02em;
    color: #ede8d8;
    margin: 2em 0 0.75em;
  }
  .prose :global(h3) {
    font-family: var(--font-eb-garamond);
    font-weight: 500;
    font-variation-settings: 'opsz' 72;
    font-size: 22px;
    color: #ede8d8;
    margin: 1.75em 0 0.5em;
  }
  .prose :global(p) {
    margin: 0 0 1.4em;
  }
  .prose :global(a) {
    color: #d4af37;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose :global(a:hover) {
    opacity: 0.8;
  }
  .prose :global(strong) {
    color: #ede8d8;
    font-weight: 600;
  }
  .prose :global(code) {
    font-family: var(--font-geist-mono);
    font-size: 0.875em;
    background: rgba(137, 174, 151, 0.12);
    border: 1px solid rgba(137, 174, 151, 0.2);
    border-radius: 4px;
    padding: 2px 6px;
    color: #e2ede6;
  }
  .prose :global(pre) {
    background: #162b1b;
    border: 1px solid rgba(137, 174, 151, 0.2);
    border-radius: 8px;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 0 0 1.4em;
  }
  .prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: 14px;
  }
  .prose :global(blockquote) {
    border-left: 3px solid #c87840;
    padding-left: 1.25rem;
    margin: 0 0 1.4em;
    color: #e2ede6;
    font-style: italic;
  }
  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5rem;
    margin: 0 0 1.4em;
  }
  .prose :global(li) {
    margin-bottom: 0.4em;
  }
  .prose :global(hr) {
    border: none;
    border-top: 1px solid rgba(137, 174, 151, 0.2);
    margin: 2em 0;
  }
  .prose :global(img) {
    border-radius: 8px;
    border: 1px solid rgba(137, 174, 151, 0.2);
    margin: 1em 0;
  }

  .back-link {
    display: inline-block;
    margin-top: 48px;
    font-size: 14px;
    color: #d4af37;
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .back-link:hover {
    opacity: 0.8;
  }

  @media (max-width: 720px) {
    .post-inner {
      padding: 40px 20px 60px;
    }
    .hero-img {
      height: 260px;
    }
  }
</style>
