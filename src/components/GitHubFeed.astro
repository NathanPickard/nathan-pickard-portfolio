---
import { Icon } from 'astro-icon/components';

const GITHUB_USER = 'nathanpickard';
const REPO_COUNT = 5;
---

<section
  class="github-feed"
  data-github-user={GITHUB_USER}
  data-repo-count={REPO_COUNT}
>
  <h4 class="feed-heading">
    <Icon name="devicon:github" size={24} aria-hidden="true" />
    Recent GitHub activity
  </h4>

  <p class="feed-status" data-feed-status>Loading repositories…</p>
  <ul class="repo-grid" hidden></ul>

  <a
    class="view-all"
    href={`https://github.com/${GITHUB_USER}`}
    target="_blank"
    rel="noopener noreferrer"
  >
    View all on GitHub →</a
  >

  <!-- Rendered at build time so it carries Astro's scoped-style attribute;
       cloned per repo in the script below (same pattern as BlueskyFeed). -->
  <template class="repo-template">
    <li class="repo-card">
      <a target="_blank" rel="noopener noreferrer" class="repo-link">
        <p class="repo-name"></p>
        <p class="repo-description" hidden></p>
        <div class="repo-meta">
          <span class="repo-lang" hidden>
            <span class="lang-dot" aria-hidden="true"></span>
            <span class="lang-name"></span>
          </span>
          <span class="repo-stats">
            <span title="Stars" class="repo-stars" hidden>
              <Icon name="mdi:star-outline" size={13} aria-hidden="true" />
              <span class="star-count"></span>
            </span>
            <time></time>
          </span>
        </div>
      </a>
    </li>
  </template>
</section>

<script>
  // Client-side GitHub feed via the public, unauthenticated REST API (no token in
  // the browser). One request per load; 60/hr per visitor IP — fine for a
  // portfolio. Cards are cloned from the build-time <template> so scoped styles
  // apply (createElement nodes would miss Astro's data-astro-cid attribute).

  // REST's `language` is a name only, so map Linguist colors; gray fallback.
  const LANG_COLORS: Record<string, string> = {
    JavaScript: '#f1e05a',
    TypeScript: '#3178c6',
    HTML: '#e34c26',
    CSS: '#563d7c',
    SCSS: '#c6538c',
    Less: '#1d365d',
    Python: '#3572A5',
    Astro: '#ff5a03',
    Vue: '#41b883',
    Svelte: '#ff3e00',
    Shell: '#89e051',
    Dockerfile: '#384d54',
    Java: '#b07219',
    Kotlin: '#A97BFF',
    Go: '#00ADD8',
    Rust: '#dea584',
    Ruby: '#701516',
    PHP: '#4F5D95',
    'C#': '#178600',
    'C++': '#f34b7d',
    C: '#555555',
    Swift: '#F05138',
    MDX: '#fcb32c',
    'Jupyter Notebook': '#DA5B0B',
    Makefile: '#427819',
  };

  type Repo = {
    name: string;
    description: string | null;
    html_url: string;
    language: string | null;
    stargazers_count: number;
    pushed_at: string;
    fork: boolean;
    archived: boolean;
  };

  function formatDate(dateStr: string) {
    return new Date(dateStr).toLocaleDateString('en-US', {
      month: 'short',
      day: 'numeric',
      year: 'numeric',
    });
  }

  function renderRepo(
    template: HTMLTemplateElement,
    repo: Repo,
  ): HTMLLIElement {
    const node = template.content.firstElementChild!.cloneNode(
      true,
    ) as HTMLLIElement;

    (node.querySelector('.repo-link') as HTMLAnchorElement).href =
      repo.html_url;
    (node.querySelector('.repo-name') as HTMLElement).textContent = repo.name;

    const desc = node.querySelector('.repo-description') as HTMLElement;
    if (repo.description) {
      desc.textContent = repo.description;
      desc.hidden = false;
    }

    if (repo.language) {
      const dot = node.querySelector('.lang-dot') as HTMLElement;
      dot.style.backgroundColor = LANG_COLORS[repo.language] ?? '#8b8b8b';
      (node.querySelector('.lang-name') as HTMLElement).textContent =
        repo.language;
      (node.querySelector('.repo-lang') as HTMLElement).hidden = false;
    }

    if (repo.stargazers_count > 0) {
      (node.querySelector('.star-count') as HTMLElement).textContent = String(
        repo.stargazers_count,
      );
      (node.querySelector('.repo-stars') as HTMLElement).hidden = false;
    }

    const time = node.querySelector('time') as HTMLTimeElement;
    time.dateTime = repo.pushed_at;
    time.textContent = formatDate(repo.pushed_at);

    return node;
  }

  function showStatus(section: HTMLElement, message: string) {
    const status = section.querySelector(
      '[data-feed-status]',
    ) as HTMLElement | null;
    const grid = section.querySelector('.repo-grid') as HTMLElement | null;
    if (grid) grid.hidden = true;
    if (status) {
      status.hidden = false;
      status.textContent = message;
    }
  }

  async function loadFeed(section: HTMLElement) {
    if (
      section.dataset.feedState === 'loading' ||
      section.dataset.feedState === 'loaded'
    ) {
      return;
    }
    section.dataset.feedState = 'loading';

    const grid = section.querySelector('.repo-grid') as HTMLUListElement;
    const status = section.querySelector(
      '[data-feed-status]',
    ) as HTMLElement | null;
    const template = section.querySelector(
      '.repo-template',
    ) as HTMLTemplateElement;
    const user = section.dataset.githubUser ?? '';
    const count = parseInt(section.dataset.repoCount ?? '5', 10);
    const cacheKey = `gh-feed:${user}`;

    const paint = (repos: Repo[]) => {
      grid.replaceChildren();
      repos.forEach((repo) => grid.appendChild(renderRepo(template, repo)));
      grid.hidden = false;
      if (status) status.hidden = true;
    };

    // Session cache so revisits (incl. View Transition navigations) are instant.
    try {
      const raw = sessionStorage.getItem(cacheKey);
      if (raw) {
        const cached = JSON.parse(raw) as { t: number; repos: Repo[] };
        if (Date.now() - cached.t < 30 * 60 * 1000) {
          paint(cached.repos);
          section.dataset.feedState = 'loaded';
          return;
        }
      }
    } catch {
      /* ignore malformed cache */
    }

    try {
      const res = await fetch(
        `https://api.github.com/users/${user}/repos?sort=pushed&direction=desc&type=owner&per_page=100`,
        { headers: { Accept: 'application/vnd.github+json' } },
      );
      if (!res.ok) {
        showStatus(section, 'Could not load repositories right now.');
        section.dataset.feedState = '';
        return;
      }
      const all = (await res.json()) as Repo[];
      const repos = all.filter((r) => !r.fork && !r.archived).slice(0, count);

      if (repos.length === 0) {
        showStatus(section, 'No repositories found.');
        section.dataset.feedState = 'loaded';
        return;
      }

      try {
        sessionStorage.setItem(
          cacheKey,
          JSON.stringify({ t: Date.now(), repos }),
        );
      } catch {
        /* storage unavailable — fine */
      }

      paint(repos);
      section.dataset.feedState = 'loaded';
    } catch (err) {
      console.warn('GitHubFeed: fetch failed', err);
      showStatus(section, 'Could not load repositories right now.');
      section.dataset.feedState = '';
    }
  }

  function initFeeds() {
    document
      .querySelectorAll<HTMLElement>('.github-feed')
      .forEach((section) => loadFeed(section));
  }

  // Homepage uses View Transitions — astro:page-load fires on first load and on
  // every client-side navigation back to this page.
  document.addEventListener('astro:page-load', initFeeds);
</script>

<style>
  .github-feed {
    min-width: 0;
    flex: 1;
  }

  .feed-heading {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
    font-size: 1.5rem;
  }

  .feed-status {
    color: #c8e0d0;
    font-size: 0.9em;
  }

  .repo-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }

  .repo-card {
    border: 1px solid #e8e6e0;
    border-radius: 10px;
    background: #fff;
    box-shadow: 0 1px 4px rgba(42, 125, 79, 0.06);
    transition:
      box-shadow 0.15s ease,
      transform 0.1s ease;
  }

  .repo-card:hover {
    box-shadow: 0 4px 20px rgba(212, 175, 55, 0.1);
    transform: translateY(-1px);
  }

  .repo-link {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1rem 1.25rem;
    text-decoration: none;
    color: inherit;
    height: 100%;
    box-sizing: border-box;
  }

  .repo-name {
    margin: 0;
    font-size: 1.1em;
    font-weight: 600;
    color: #d4af37;
  }

  .repo-description {
    margin: 0;
    font-size: 0.95em;
    color: #e2ede6;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .repo-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.8em;
    color: #c8e0d0;
    margin-top: auto;
    padding-top: 0.5rem;
  }
  .repo-meta time {
    font-size: 1.1em;
  }

  .repo-lang {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .lang-dot {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .repo-stats {
    display: flex;
    gap: 0.75rem;
  }

  .repo-stars {
    display: flex;
    align-items: center;
    gap: 0.2rem;
  }

  .view-all {
    display: inline-block;
    margin-top: 1.25rem;
    font-size: 1rem;
  }
</style>
