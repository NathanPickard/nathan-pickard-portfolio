---
import { Icon } from "astro-icon/components";
const BLUESKY_HANDLE = "nathanpickard.bsky.social";
const FEED_LIMIT = 10;

interface EmbedImage {
  thumb: string;
  fullsize: string;
  alt: string;
  aspectRatio?: { width: number; height: number };
}

interface BlueskyPost {
  post: {
    uri: string;
    cid: string;
    author: {
      handle: string;
      displayName: string;
    };
    record: {
      text: string;
      createdAt: string;
    };
    embed?: {
      $type: string;
      images?: EmbedImage[];
      external?: {
        uri: string;
        title: string;
        thumb?: string;
      };
    };
    indexedAt: string;
    likeCount?: number;
    repostCount?: number;
    replyCount?: number;
  };
  reason?: {
    $type: string;
  };
}

let feed: BlueskyPost[] = [];
let fetchError = false;
let initialCursor = "";

try {
  const res = await fetch(
    `https://public.api.bsky.app/xrpc/app.bsky.feed.getAuthorFeed?actor=${BLUESKY_HANDLE}&limit=${FEED_LIMIT}&filter=posts_no_replies`,
  );
  if (res.ok) {
    const data = await res.json();
    feed = (data.feed as BlueskyPost[]).filter(
      (item) => !item.reason, // exclude reposts
    );
    initialCursor = data.cursor ?? "";
  } else {
    fetchError = true;
  }
} catch {
  fetchError = true;
}

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
  });
}

function postUrl(uri: string) {
  const rkey = uri.split("/").pop();
  return `https://bsky.app/profile/${BLUESKY_HANDLE}/post/${rkey}`;
}
---

<section class="bluesky-feed">
  <h4 class="feed-heading">
    <Icon name="bluesky" size={24} aria-hidden="true" />
    Bluesky
  </h4>

  {fetchError && <p class="feed-error">Could not load posts right now.</p>}

  {
    !fetchError && feed.length === 0 && (
      <p class="feed-error">No posts found.</p>
    )
  }

  <div id="feed-scroll" class="feed-scroll">
    <ul
      class="posts"
      id="bluesky-posts"
      data-handle={BLUESKY_HANDLE}
      data-limit={FEED_LIMIT}
      data-cursor={initialCursor}
    >
      {
        feed.map((item) => {
          const embed = item.post.embed;
          const images =
            embed?.$type === "app.bsky.embed.images#view"
              ? (embed.images ?? [])
              : [];
          const externalThumb =
            embed?.$type === "app.bsky.embed.external#view" &&
            embed.external?.thumb
              ? embed.external.thumb
              : null;

          return (
            <li class="post">
              <a
                href={postUrl(item.post.uri)}
                target="_blank"
                rel="noopener noreferrer"
                class="post-link"
              >
                <p class="post-date">
                  <time datetime={item.post.record.createdAt}>
                    {formatDate(item.post.record.createdAt)}
                  </time>
                </p>
                <p class="post-text">{item.post.record.text}</p>

                {images.length > 0 && (
                  <div
                    class={`post-images count-${Math.min(images.length, 4)}`}
                  >
                    {images.slice(0, 4).map((img) => (
                      <img
                        src={img.thumb}
                        alt={img.alt}
                        class="post-img"
                        loading="lazy"
                      />
                    ))}
                  </div>
                )}

                {externalThumb && images.length === 0 && (
                  <div class="post-external-thumb">
                    <img
                      src={externalThumb}
                      alt={embed?.external?.title ?? ""}
                      class="post-img"
                      loading="lazy"
                    />
                  </div>
                )}

                <div class="post-meta">
                  <span class="post-stats">
                    {item.post.replyCount !== undefined && (
                      <span title="Replies" class="stat stat-reply">
                        <Icon
                          name="mdi:message-outline"
                          size={18}
                          aria-hidden="true"
                        />
                        <span class="stat-count">{item.post.replyCount}</span>
                      </span>
                    )}
                    {item.post.repostCount !== undefined && (
                      <span title="Reposts" class="stat stat-repost">
                        <Icon name="mdi:repeat" size={18} aria-hidden="true" />
                        <span class="stat-count">{item.post.repostCount}</span>
                      </span>
                    )}
                    {item.post.likeCount !== undefined && (
                      <span title="Likes" class="stat stat-like">
                        <Icon
                          name="mdi:heart-outline"
                          size={18}
                          aria-hidden="true"
                        />
                        <span class="stat-count">{item.post.likeCount}</span>
                      </span>
                    )}
                  </span>
                </div>
              </a>
            </li>
          );
        })
      }
    </ul>

    <div id="feed-sentinel" aria-hidden="true"></div>
    <p id="feed-loading" class="feed-loading" hidden>Loading...</p>
    <p id="feed-end" class="feed-end" hidden>You're all caught up.</p>
  </div>

  <a
    class="view-all"
    href={`https://bsky.app/profile/${BLUESKY_HANDLE}`}
    target="_blank"
    rel="noopener noreferrer"
  >
    View all on Bluesky →
  </a>

  <template id="post-template">
    <li class="post">
      <a target="_blank" rel="noopener noreferrer" class="post-link">
        <p class="post-date"><time></time></p>
        <p class="post-text"></p>
        <div class="post-images" hidden></div>
        <div class="post-external-thumb" hidden>
          <img class="post-img" loading="lazy" alt="" />
        </div>
        <div class="post-meta">
          <span class="post-stats">
            <span title="Replies" class="stat stat-reply">
              <Icon name="mdi:message-outline" size={18} aria-hidden="true" />
              <span class="stat-count"></span>
            </span>
            <span title="Reposts" class="stat stat-repost">
              <Icon name="mdi:repeat" size={18} aria-hidden="true" />
              <span class="stat-count"></span>
            </span>
            <span title="Likes" class="stat stat-like">
              <Icon name="mdi:heart-outline" size={18} aria-hidden="true" />
              <span class="stat-count"></span>
            </span>
          </span>
        </div>
      </a>
    </li>
  </template>

  <template id="post-image-template">
    <img class="post-img" loading="lazy" alt="" />
  </template>
</section>

<script>
  type EmbedImage = { thumb: string; alt: string };
  type Embed = {
    $type: string;
    images?: EmbedImage[];
    external?: { uri: string; title: string; thumb?: string };
  };
  type FeedItem = {
    post: {
      uri: string;
      record: { text: string; createdAt: string };
      embed?: Embed;
      replyCount?: number;
      repostCount?: number;
      likeCount?: number;
    };
    reason?: { $type: string };
  };

  const scrollEl = document.getElementById("feed-scroll") as HTMLDivElement;
  const list = document.getElementById("bluesky-posts") as HTMLUListElement;
  const sentinel = document.getElementById("feed-sentinel")!;
  const loadingEl = document.getElementById(
    "feed-loading",
  ) as HTMLParagraphElement;
  const endEl = document.getElementById("feed-end") as HTMLParagraphElement;
  const postTemplate = document.getElementById(
    "post-template",
  ) as HTMLTemplateElement;
  const imageTemplate = document.getElementById(
    "post-image-template",
  ) as HTMLTemplateElement;

  const HANDLE = list.dataset.handle!;
  const LIMIT = list.dataset.limit!;
  let cursor = list.dataset.cursor ?? "";
  let loading = false;

  function formatDate(dateStr: string) {
    return new Date(dateStr).toLocaleDateString("en-US", {
      month: "short",
      day: "numeric",
      year: "numeric",
    });
  }

  function postUrl(uri: string) {
    const rkey = uri.split("/").pop();
    return `https://bsky.app/profile/${HANDLE}/post/${rkey}`;
  }

  function renderPost(item: FeedItem): HTMLLIElement {
    const node = postTemplate.content.firstElementChild!.cloneNode(
      true,
    ) as HTMLLIElement;

    const link = node.querySelector(".post-link") as HTMLAnchorElement;
    link.href = postUrl(item.post.uri);

    const time = node.querySelector(".post-date time") as HTMLTimeElement;
    time.dateTime = item.post.record.createdAt;
    time.textContent = formatDate(item.post.record.createdAt);

    (node.querySelector(".post-text") as HTMLElement).textContent =
      item.post.record.text;

    const embed = item.post.embed;
    const images =
      embed?.$type === "app.bsky.embed.images#view" ? (embed.images ?? []) : [];
    const externalThumb =
      embed?.$type === "app.bsky.embed.external#view" && embed.external?.thumb
        ? embed.external.thumb
        : null;

    if (images.length > 0) {
      const grid = node.querySelector(".post-images") as HTMLDivElement;
      grid.hidden = false;
      grid.classList.add(`count-${Math.min(images.length, 4)}`);
      images.slice(0, 4).forEach((img) => {
        const imgEl = imageTemplate.content.firstElementChild!.cloneNode(
          true,
        ) as HTMLImageElement;
        imgEl.src = img.thumb;
        imgEl.alt = img.alt;
        grid.appendChild(imgEl);
      });
    } else if (externalThumb) {
      const ext = node.querySelector(
        ".post-external-thumb",
      ) as HTMLDivElement;
      ext.hidden = false;
      const img = ext.querySelector("img") as HTMLImageElement;
      img.src = externalThumb;
      img.alt = embed?.external?.title ?? "";
    }

    const setStat = (selector: string, count: number | undefined) => {
      const el = node.querySelector(selector) as HTMLSpanElement;
      if (count != null) {
        (el.querySelector(".stat-count") as HTMLElement).textContent =
          String(count);
      } else {
        el.hidden = true;
      }
    };
    setStat(".stat-reply", item.post.replyCount);
    setStat(".stat-repost", item.post.repostCount);
    setStat(".stat-like", item.post.likeCount);

    return node;
  }

  async function loadMore() {
    if (loading || !cursor) return;
    loading = true;
    loadingEl.hidden = false;

    try {
      const url = `https://public.api.bsky.app/xrpc/app.bsky.feed.getAuthorFeed?actor=${HANDLE}&limit=${LIMIT}&filter=posts_no_replies&cursor=${encodeURIComponent(cursor)}`;
      const res = await fetch(url);
      if (!res.ok) throw new Error("fetch failed");

      const data = await res.json();
      const posts = (data.feed as FeedItem[]).filter((item) => !item.reason);

      posts.forEach((item) => list.appendChild(renderPost(item)));

      cursor = data.cursor ?? "";
      if (!cursor) {
        endEl.hidden = false;
        observer?.disconnect();
      }
    } catch {
      // silently fail — existing posts remain visible
    } finally {
      loading = false;
      loadingEl.hidden = true;
    }
  }

  let observer: IntersectionObserver | undefined;

  if (cursor) {
    observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) loadMore();
      },
      { root: scrollEl, rootMargin: "200px" },
    );
    observer.observe(sentinel);
  } else {
    endEl.hidden = false;
  }
</script>

<style>
  .bluesky-feed {
    min-width: 0;
    flex: 1;
  }

  .feed-heading {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
    font-size: 1.5rem;
  }

  .feed-error {
    color: #c8e0d0;
    font-size: 0.9em;
  }

  .feed-loading,
  .feed-end {
    font-size: 0.85em;
    color: #c8e0d0;
    text-align: center;
    margin: 1rem 0 0;
  }

  .feed-scroll {
    height: 640px;
    overflow-y: auto;
    padding: 0.25rem 0.75rem 0.25rem 0.25rem;
    scrollbar-gutter: stable;
    scrollbar-width: thin;
    scrollbar-color: rgba(137, 174, 151, 0.3) transparent;
  }

  :global(.posts) {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0.85rem;
  }

  :global(.post) {
    width: 100%;
    border: 1px solid #e8e6e0;
    border-radius: 10px;
    background: #fff;
    box-shadow: 0 1px 4px rgba(42, 125, 79, 0.06);
    transition:
      box-shadow 0.15s ease,
      transform 0.1s ease;
  }

  :global(.post:hover) {
    box-shadow: 0 4px 20px rgba(212, 175, 55, 0.1);
    transform: translateY(-1px);
  }

  :global(.post-link) {
    display: block;
    padding: 1rem 1.25rem;
    text-decoration: none;
    color: inherit;
  }

  :global(.post-text) {
    margin: 0 0 0.5rem 0;
    font-size: 1.05em;
    line-height: 1.55;
    white-space: pre-wrap;
  }

  :global(.post-images) {
    display: grid;
    gap: 4px;
    margin: 0.5rem 0;
    border-radius: 6px;
    overflow: hidden;
  }

  :global(.post-images.count-1) {
    grid-template-columns: 1fr;
  }

  :global(.post-images.count-2) {
    grid-template-columns: 1fr 1fr;
  }

  :global(.post-images.count-3) {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
  }

  :global(.post-images.count-3 .post-img:first-child) {
    grid-column: 1 / -1;
  }

  :global(.post-images.count-4) {
    grid-template-columns: 1fr 1fr;
  }

  :global(.post-img) {
    width: 100%;
    height: 220px;
    object-fit: cover;
    border-radius: 0;
    display: block;
    margin: 0;
  }

  :global(.post-images.count-1 .post-img) {
    max-height: 400px;
    height: auto;
  }

  :global(.post-external-thumb) {
    margin: 0.5rem 0;
    border-radius: 6px;
    overflow: hidden;
  }

  :global(.post-external-thumb .post-img) {
    height: 180px;
  }

  :global(.post-meta) {
    display: flex;
    align-items: center;
    font-size: 0.8em;
    color: #c8e0d0;
  }

  :global(.post-date) {
    margin: 0 0 0.4rem 0;
    font-size: 1em;
    color: #c8e0d0;
  }

  :global(.post-stats) {
    display: flex;
    gap: 0.75rem;
    font-size: 1rem;
  }

  :global(.stat) {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  :global(.stat-icon) {
    display: inline-block;
    vertical-align: middle;
    flex-shrink: 0;
  }

  :global(.stat-reply) {
    color: #8aae97;
  }
  :global(.stat-repost) {
    color: #8aae97;
  }
  :global(.stat-like) {
    color: #8aae97;
  }

  .view-all {
    display: inline-block;
    margin-top: 1.25rem;
    font-size: 1rem;
  }

  @media (max-width: 720px) {
    .feed-scroll {
      height: 400px;
    }
  }
</style>
