---
import { Icon } from 'astro-icon/components';
const BLUESKY_HANDLE = 'nathanpickard.bsky.social';
const FEED_LIMIT = 10;

interface EmbedImage {
  thumb: string;
  fullsize: string;
  alt: string;
  aspectRatio?: { width: number; height: number };
}

interface BlueskyPost {
  post: {
    uri: string;
    cid: string;
    author: {
      handle: string;
      displayName: string;
    };
    record: {
      text: string;
      createdAt: string;
    };
    embed?: {
      $type: string;
      images?: EmbedImage[];
      external?: {
        uri: string;
        title: string;
        thumb?: string;
      };
    };
    indexedAt: string;
    likeCount?: number;
    repostCount?: number;
    replyCount?: number;
  };
  reason?: {
    $type: string;
  };
}

let feed: BlueskyPost[] = [];
let fetchError = false;
let initialCursor = '';

try {
  const res = await fetch(
    `https://public.api.bsky.app/xrpc/app.bsky.feed.getAuthorFeed?actor=${BLUESKY_HANDLE}&limit=${FEED_LIMIT}&filter=posts_no_replies`,
  );
  if (res.ok) {
    const data = await res.json();
    feed = (data.feed as BlueskyPost[]).filter(
      (item) => !item.reason, // exclude reposts
    );
    initialCursor = data.cursor ?? '';
  } else {
    fetchError = true;
  }
} catch {
  fetchError = true;
}

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  });
}

function postUrl(uri: string) {
  const rkey = uri.split('/').pop();
  return `https://bsky.app/profile/${BLUESKY_HANDLE}/post/${rkey}`;
}
---

<section class="bluesky-feed">
  <h5 class="feed-heading">
    <Icon name="bluesky" size={24} aria-hidden="true" />
    Latest from Bluesky
  </h5>

  {fetchError && <p class="feed-error">Could not load posts right now.</p>}

  {
    !fetchError && feed.length === 0 && (
      <p class="feed-error">No posts found.</p>
    )
  }

  <div id="feed-scroll" class="feed-scroll">
    <ul
      class="posts"
      id="bluesky-posts"
      data-handle={BLUESKY_HANDLE}
      data-limit={FEED_LIMIT}
      data-cursor={initialCursor}
    >
      {
        feed.map((item) => {
          const embed = item.post.embed;
          const images =
            embed?.$type === 'app.bsky.embed.images#view'
              ? (embed.images ?? [])
              : [];
          const externalThumb =
            embed?.$type === 'app.bsky.embed.external#view' &&
            embed.external?.thumb
              ? embed.external.thumb
              : null;

          return (
            <li class="post">
              <a
                href={postUrl(item.post.uri)}
                target="_blank"
                rel="noopener noreferrer"
                class="post-link"
              >
                <p class="post-text">{item.post.record.text}</p>

                {images.length > 0 && (
                  <div
                    class={`post-images count-${Math.min(images.length, 4)}`}
                  >
                    {images.slice(0, 4).map((img) => (
                      <img
                        src={img.thumb}
                        alt={img.alt}
                        class="post-img"
                        loading="lazy"
                      />
                    ))}
                  </div>
                )}

                {externalThumb && images.length === 0 && (
                  <div class="post-external-thumb">
                    <img
                      src={externalThumb}
                      alt={embed?.external?.title ?? ''}
                      class="post-img"
                      loading="lazy"
                    />
                  </div>
                )}

                <div class="post-meta">
                  <time datetime={item.post.record.createdAt}>
                    {formatDate(item.post.record.createdAt)}
                  </time>
                  <span class="post-stats">
                    {item.post.replyCount !== undefined && (
                      <span title="Replies" class="stat stat-reply">
                        <Icon name="mdi:message-outline" size={14} aria-hidden="true" />
                        {item.post.replyCount}
                      </span>
                    )}
                    {item.post.repostCount !== undefined && (
                      <span title="Reposts" class="stat stat-repost">
                        <Icon name="mdi:repeat" size={14} aria-hidden="true" />
                        {item.post.repostCount}
                      </span>
                    )}
                    {item.post.likeCount !== undefined && (
                      <span title="Likes" class="stat stat-like">
                        <Icon name="mdi:heart-outline" size={14} aria-hidden="true" />
                        {item.post.likeCount}
                      </span>
                    )}
                  </span>
                </div>
              </a>
            </li>
          );
        })
      }
    </ul>

    <div id="feed-sentinel" aria-hidden="true"></div>
    <p id="feed-loading" class="feed-loading" hidden>Loading...</p>
    <p id="feed-end" class="feed-end" hidden>You're all caught up.</p>
  </div>

  <a
    class="view-all"
    href={`https://bsky.app/profile/${BLUESKY_HANDLE}`}
    target="_blank"
    rel="noopener noreferrer"
  >
    View all on Bluesky →
  </a>
</section>

<script>
  const scrollEl = document.getElementById('feed-scroll') as HTMLDivElement;
  const list = document.getElementById('bluesky-posts') as HTMLUListElement;
  const sentinel = document.getElementById('feed-sentinel')!;
  const loadingEl = document.getElementById(
    'feed-loading',
  ) as HTMLParagraphElement;
  const endEl = document.getElementById('feed-end') as HTMLParagraphElement;

  const HANDLE = list.dataset.handle!;
  const LIMIT = list.dataset.limit!;
  let cursor = list.dataset.cursor ?? '';
  let loading = false;

  function formatDate(dateStr: string) {
    return new Date(dateStr).toLocaleDateString('en-US', {
      month: 'short',
      day: 'numeric',
      year: 'numeric',
    });
  }

  function postUrl(uri: string) {
    const rkey = uri.split('/').pop();
    return `https://bsky.app/profile/${HANDLE}/post/${rkey}`;
  }

  function buildImagesHtml(images: { thumb: string; alt: string }[]) {
    const count = Math.min(images.length, 4);
    const imgs = images
      .slice(0, 4)
      .map(
        (img) =>
          `<img src="${img.thumb}" alt="${img.alt.replace(/"/g, '&quot;')}" class="post-img" loading="lazy" />`,
      )
      .join('');
    return `<div class="post-images count-${count}">${imgs}</div>`;
  }

  function iconSvg(path: string) {
    return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true" class="stat-icon">${path}</svg>`;
  }
  const ICON_REPLY = iconSvg('<path d="M9 22a1 1 0 0 1-1-1v-3H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2h-6.1l-3.7 3.71c-.2.18-.45.29-.7.29H9m1-6v3.08L13.08 16H20V4H4v12h6z"/>');
  const ICON_REPOST = iconSvg('<path d="M6 5.75L10.25 10H7v6h6.5l2 2H7a2 2 0 0 1-2-2v-6H1.75L6 5.75M18 18.25L13.75 14H17V8h-6.5l-2-2H17a2 2 0 0 1 2 2v6h3.25L18 18.25z"/>');
  const ICON_LIKE = iconSvg('<path d="M12.1 18.55l-.1.1-.11-.1C7.14 14.24 4 11.39 4 8.5 4 6.5 5.5 5 7.5 5c1.54 0 3.04 1 3.57 2.36h1.86C13.46 6 14.96 5 16.5 5c2 0 3.5 1.5 3.5 3.5 0 2.89-3.14 5.74-7.9 10.05M16.5 3c-1.74 0-3.41.81-4.5 2.08C10.91 3.81 9.24 3 7.5 3 4.42 3 2 5.41 2 8.5c0 3.77 3.4 6.86 8.55 11.53L12 21.35l1.45-1.32C18.6 15.36 22 12.27 22 8.5 22 5.41 19.58 3 16.5 3z"/>');

  function buildPostHtml(item: any) {
    const embed = item.post.embed;
    const images =
      embed?.$type === 'app.bsky.embed.images#view' ? (embed.images ?? []) : [];
    const externalThumb =
      embed?.$type === 'app.bsky.embed.external#view' && embed.external?.thumb
        ? embed.external.thumb
        : null;

    const text = item.post.record.text
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;');

    const imagesHtml = images.length > 0 ? buildImagesHtml(images) : '';
    const externalHtml =
      externalThumb && images.length === 0
        ? `<div class="post-external-thumb"><img src="${externalThumb}" alt="${(embed?.external?.title ?? '').replace(/"/g, '&quot;')}" class="post-img" loading="lazy" /></div>`
        : '';

    const replies =
      item.post.replyCount != null
        ? `<span title="Replies" class="stat stat-reply">${ICON_REPLY} ${item.post.replyCount}</span>`
        : '';
    const reposts =
      item.post.repostCount != null
        ? `<span title="Reposts" class="stat stat-repost">${ICON_REPOST} ${item.post.repostCount}</span>`
        : '';
    const likes =
      item.post.likeCount != null
        ? `<span title="Likes" class="stat stat-like">${ICON_LIKE} ${item.post.likeCount}</span>`
        : '';

    return `
      <li class="post">
        <a href="${postUrl(item.post.uri)}" target="_blank" rel="noopener noreferrer" class="post-link">
          <p class="post-text">${text}</p>
          ${imagesHtml}
          ${externalHtml}
          <div class="post-meta">
            <time datetime="${item.post.record.createdAt}">${formatDate(item.post.record.createdAt)}</time>
            <span class="post-stats">${replies}${reposts}${likes}</span>
          </div>
        </a>
      </li>
    `;
  }

  async function loadMore() {
    if (loading || !cursor) return;
    loading = true;
    loadingEl.hidden = false;

    try {
      const url = `https://public.api.bsky.app/xrpc/app.bsky.feed.getAuthorFeed?actor=${HANDLE}&limit=${LIMIT}&filter=posts_no_replies&cursor=${encodeURIComponent(cursor)}`;
      const res = await fetch(url);
      if (!res.ok) throw new Error('fetch failed');

      const data = await res.json();
      const posts = (data.feed as any[]).filter((item) => !item.reason);

      posts.forEach((item) => {
        list.insertAdjacentHTML('beforeend', buildPostHtml(item));
      });

      cursor = data.cursor ?? '';
      if (!cursor) {
        endEl.hidden = false;
        observer?.disconnect();
      }
    } catch {
      // silently fail — existing posts remain visible
    } finally {
      loading = false;
      loadingEl.hidden = true;
    }
  }

  let observer: IntersectionObserver | undefined;

  if (cursor) {
    observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) loadMore();
      },
      { root: scrollEl, rootMargin: '200px' },
    );
    observer.observe(sentinel);
  } else {
    endEl.hidden = false;
  }
</script>

<style>
  .bluesky-feed {
    min-width: 0;
    flex: 1;
  }

  .feed-heading {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .feed-error {
    color: rgb(var(--gray));
    font-size: 0.9em;
  }

  .feed-loading,
  .feed-end {
    font-size: 0.85em;
    color: rgb(var(--gray));
    text-align: center;
    margin: 1rem 0 0;
  }

  .feed-scroll {
    height: 640px;
    overflow-y: auto;
    padding: 0.25rem 0.25rem;
    scrollbar-width: thin;
    scrollbar-color: rgb(var(--gray-light)) transparent;
  }

  :global(.posts) {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  :global(.post) {
    width: 100%;
    max-width: 450px;
    border: 1px solid #e8e6e0;
    border-radius: 10px;
    background: #fff;
    box-shadow: 0 1px 4px rgba(42, 125, 79, 0.06);
    transition:
      box-shadow 0.15s ease,
      transform 0.1s ease;
  }

  :global(.post:hover) {
    box-shadow: var(--box-shadow);
    transform: translateY(-1px);
  }

  :global(.post-link) {
    display: block;
    padding: 1rem 1.25rem;
    text-decoration: none;
    color: inherit;
  }

  :global(.post-text) {
    margin: 0 0 0.5rem 0;
    font-size: 0.95em;
    line-height: 1.5;
    white-space: pre-wrap;
  }

  :global(.post-images) {
    display: grid;
    gap: 4px;
    margin: 0.5rem 0;
    border-radius: 6px;
    overflow: hidden;
  }

  :global(.post-images.count-1) {
    grid-template-columns: 1fr;
  }

  :global(.post-images.count-2) {
    grid-template-columns: 1fr 1fr;
  }

  :global(.post-images.count-3) {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
  }

  :global(.post-images.count-3 .post-img:first-child) {
    grid-column: 1 / -1;
  }

  :global(.post-images.count-4) {
    grid-template-columns: 1fr 1fr;
  }

  :global(.post-img) {
    width: 100%;
    height: 220px;
    object-fit: cover;
    border-radius: 0;
    display: block;
    margin: 0;
  }

  :global(.post-images.count-1 .post-img) {
    max-height: 400px;
    height: auto;
  }

  :global(.post-external-thumb) {
    margin: 0.5rem 0;
    border-radius: 6px;
    overflow: hidden;
  }

  :global(.post-external-thumb .post-img) {
    height: 180px;
  }

  :global(.post-meta) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.8em;
    color: rgb(var(--gray));
  }

  :global(.post-stats) {
    display: flex;
    gap: 0.75rem;
  }

  :global(.stat) {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  :global(.stat-icon) {
    display: inline-block;
    vertical-align: middle;
    flex-shrink: 0;
  }

  :global(.stat-reply) { color: #0085ff; }
  :global(.stat-repost) { color: #22c55e; }
  :global(.stat-like) { color: #f43f5e; }

  .view-all {
    display: inline-block;
    margin-top: 1.25rem;
    font-size: 0.9em;
  }

  @media (max-width: 720px) {
    .feed-scroll {
      height: 400px;
    }
  }
</style>
