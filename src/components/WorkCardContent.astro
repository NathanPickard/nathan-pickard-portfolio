---
import { labelOverrides, skipTiles } from '../data/workIconMap';

interface Props {
  role: string;
  client?: string;
  blurb: string;
  wins: string[];
  stack: string[];
}

const { role, client, blurb, wins, stack } = Astro.props;
const visibleStack = stack
  .filter((s) => !skipTiles.has(s))
  .map((s) => labelOverrides[s] ?? s);
---

<div class="detail-role">{role}</div>
{client && <div class="detail-client">{client}</div>}
<p class="detail-blurb">{blurb}</p>
{wins.length > 0 && (
  <div class="detail-wins">
    {wins.map((win) => <span class="win">{win}</span>)}
  </div>
)}
{visibleStack.length > 0 && (
  <div class="detail-stack">
    <span class="stack-label">Stack</span>
    <span class="stack-list">{visibleStack.join(' · ')}</span>
  </div>
)}

<style>
  .detail-role {
    font-weight: 600;
    font-size: 19px;
    margin-bottom: 4px;
    color: #ede8d8;
  }
  .detail-client {
    font-size: 14px;
    font-family: var(--font-dm-sans);
    color: #a8c8b4;
    margin-bottom: 20px;
  }
  .detail-blurb {
    font-size: 17px;
    line-height: 1.7;
    color: #e2ede6;
    margin: 0 0 24px;
    max-width: 560px;
  }
  .detail-wins {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 24px;
  }
  .win {
    background: rgba(212, 175, 55, 0.15);
    color: #d4af37;
    padding: 5px 14px;
    border-radius: 999px;
    font: 500 14px var(--font-dm-sans);
  }
  .detail-stack {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-top: 20px;
    border-top: 1px solid rgba(137, 174, 151, 0.2);
  }
  .stack-label {
    font-family: var(--font-dm-sans);
    font-size: 13px;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: #d4af37;
    font-weight: 500;
  }
  .stack-list {
    font-family: var(--font-dm-sans);
    font-size: 15px;
    line-height: 1.7;
    color: #a8c8b4;
  }
</style>
