---
import { Icon } from 'astro-icon/components';

const year = new Date().getFullYear();
const socials = [
  {
    label: 'GitHub',
    href: 'https://github.com/nathanpickard',
    icon: 'devicon:github',
    invert: true,
  },
  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/in/nathanpickard/',
    icon: 'devicon:linkedin',
    invert: false,
  },
  {
    label: 'Bluesky',
    href: 'https://bsky.app/profile/nathanpickard.bsky.social',
    icon: 'bluesky',
    invert: false,
  },
  {
    label: 'X / Twitter',
    href: 'https://x.com/NathanPickard',
    icon: 'devicon:twitter',
    invert: true,
  },
  {
    label: 'Email',
    href: 'mailto:nathanppickard@gmail.com',
    icon: 'mdi:email-outline',
    invert: false,
  },
];
---

<footer class="dark-footer">
  <div class="dark-footer-grid">
    <div>
      <div class="dark-footer-name">Nathan Pickard</div>
      <div class="dark-footer-sub">Software Engineer · Portland, OR</div>
    </div>
    <div class="dark-footer-links">
      {
        socials.map((s) => (
          <a
            href={s.href}
            target={s.href.startsWith('http') ? '_blank' : undefined}
            rel={s.href.startsWith('http') ? 'noopener noreferrer' : undefined}
            aria-label={s.label}
            class="social-link"
            data-invert={s.invert ? 'true' : undefined}
          >
            <Icon name={s.icon} size={24} aria-hidden="true" />
          </a>
        ))
      }
    </div>
    <div class="dark-footer-copy">© {year}</div>
  </div>
</footer>

<style>
  .dark-footer {
    background: #162b1b;
    border-top: 1px solid rgba(137, 174, 151, 0.2);
    padding: 48px 60px;
    margin-top: 80px;
  }
  .dark-footer-grid {
    max-width: 1240px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    align-items: center;
  }
  .dark-footer-name {
    font-family: var(--font-fraunces);
    font-weight: 500;
    font-variation-settings: 'opsz' 72;
    font-size: 20px;
    letter-spacing: -0.01em;
    color: #ede8d8;
  }
  .dark-footer-sub {
    font-size: 12px;
    color: #c8e0d0;
    margin-top: 4px;
  }
  .dark-footer-links {
    display: flex;
    gap: 10px;
    justify-content: center;
    align-items: center;
  }
  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 7px;
    border-radius: 6px;
    color: #e2ede6;
    text-decoration: none;
    transition:
      background 0.2s,
      color 0.2s;
  }
  .social-link:hover {
    background: rgba(212, 175, 55, 0.15);
    color: #ede8d8;
  }
  .social-link :global(svg) {
    transition: transform 0.2s;
  }
  .social-link:hover :global(svg) {
    transform: translateY(-1px);
  }
  .social-link[data-invert='true'] :global(svg) {
    filter: invert(1);
  }
  .dark-footer-copy {
    font-family: var(--font-geist-mono);
    font-size: 12px;
    color: #c8e0d0;
    text-align: right;
  }

  @media (max-width: 900px) {
    .dark-footer {
      padding: 32px 24px;
      margin-top: 48px;
    }
    .dark-footer-grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .dark-footer-copy {
      text-align: left;
    }
    .dark-footer-links {
      justify-content: flex-start;
    }
  }
</style>
